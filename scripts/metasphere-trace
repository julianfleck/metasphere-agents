#!/bin/bash
# metasphere-trace - Command trace capture and analysis
#
# Captures command output for review agents to analyze.
#
# Usage:
#   metasphere trace run "command"     Execute and capture
#   metasphere trace list [--errors]   List recent traces
#   metasphere trace show ID           Show trace details
#   metasphere trace analyze ID        Analyze for errors
#   metasphere trace search "pattern"  Search traces

set -e

METASPHERE_DIR="${METASPHERE_DIR:-$HOME/.metasphere}"
TRACES_DIR="$METASPHERE_DIR/traces"
AGENT_ID="${METASPHERE_AGENT_ID:-@shell}"
SCOPE="${METASPHERE_SCOPE:-$PWD}"

mkdir -p "$TRACES_DIR"

# Colors
if [[ -t 1 ]]; then
    RED=$'\033[0;31m'
    YELLOW=$'\033[1;33m'
    GREEN=$'\033[0;32m'
    CYAN=$'\033[0;36m'
    DIM=$'\033[2m'
    BOLD=$'\033[1m'
    NC=$'\033[0m'
else
    RED='' YELLOW='' GREEN='' CYAN='' DIM='' BOLD='' NC=''
fi

# Generate trace ID
gen_trace_id() {
    echo "trace-$(date +%s)-$$"
}

# =============================================================================
# Run command with trace capture
# =============================================================================

cmd_run() {
    local command="$*"
    [[ -z "$command" ]] && {
        echo "Usage: metasphere trace run \"command\""
        exit 1
    }

    local trace_id=$(gen_trace_id)
    local date_dir="$TRACES_DIR/$(date +%Y-%m-%d)"
    local time_prefix="$(date +%H-%M-%S)"
    local cmd_slug=$(echo "$command" | tr ' /' '-' | head -c 30)

    mkdir -p "$date_dir"

    local stdout_file="$date_dir/${time_prefix}-${cmd_slug}.stdout"
    local stderr_file="$date_dir/${time_prefix}-${cmd_slug}.stderr"
    local meta_file="$date_dir/${time_prefix}-${cmd_slug}.json"

    local start_time=$(date +%s)
    local exit_code=0

    # Execute with capture
    set +e
    eval "$command" > "$stdout_file" 2> "$stderr_file"
    exit_code=$?
    set -e

    local end_time=$(date +%s)
    local duration=$(( (end_time - start_time) * 1000 ))  # Convert to ms

    # Analyze output for errors
    local error_detected=false
    local error_type=""
    local error_summary=""

    if [[ $exit_code -ne 0 ]]; then
        error_detected=true
        error_type="exit_code"
        error_summary="Command exited with code $exit_code"
    fi

    # Check for common error patterns
    if grep -qi "error\|failed\|exception\|fatal" "$stderr_file" 2>/dev/null; then
        error_detected=true
        [[ -z "$error_type" ]] && error_type="stderr_error"
        error_summary=$(grep -i "error\|failed\|exception\|fatal" "$stderr_file" | head -1)
    fi

    if grep -qi "error\|failed\|FAIL" "$stdout_file" 2>/dev/null; then
        error_detected=true
        [[ -z "$error_type" ]] && error_type="stdout_error"
        [[ -z "$error_summary" ]] && error_summary=$(grep -i "error\|failed\|FAIL" "$stdout_file" | head -1)
    fi

    # Write metadata
    jq -n \
        --arg id "$trace_id" \
        --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        --arg agent "$AGENT_ID" \
        --arg scope "$SCOPE" \
        --arg cmd "$command" \
        --argjson exit "$exit_code" \
        --argjson duration "$duration" \
        --arg stdout "$stdout_file" \
        --arg stderr "$stderr_file" \
        --argjson error "$error_detected" \
        --arg error_type "$error_type" \
        --arg error_summary "$error_summary" \
        '{
            id: $id,
            timestamp: $ts,
            agent: $agent,
            scope: $scope,
            command: $cmd,
            exit_code: $exit,
            duration_ms: $duration,
            stdout_file: $stdout,
            stderr_file: $stderr,
            error_detected: $error,
            error_type: $error_type,
            error_summary: $error_summary
        }' > "$meta_file"

    # Append to index
    cat "$meta_file" >> "$TRACES_DIR/index.jsonl"

    # Output to terminal
    cat "$stdout_file"
    cat "$stderr_file" >&2

    # Show trace info
    if $error_detected; then
        echo -e "\n${RED}─── Trace $trace_id: ERROR ───${NC}" >&2
        echo -e "${DIM}$error_summary${NC}" >&2
    else
        echo -e "\n${DIM}─── Trace $trace_id: OK (${duration}ms) ───${NC}" >&2
    fi

    # Notify review agents on error
    if $error_detected; then
        notify_reviewers "$trace_id" "$meta_file"
    fi

    return $exit_code
}

# =============================================================================
# Notify review agents of error
# =============================================================================

notify_reviewers() {
    local trace_id="$1"
    local meta_file="$2"

    # Find review agents for this scope
    local scope="$SCOPE"
    local script_dir="$(cd "$(dirname "$0")" && pwd)"

    # Check for project-level reviewer
    while [[ "$scope" != "/" && "$scope" != "$HOME" ]]; do
        local reviewer_dir="$scope/.metasphere/agents/@reviewer"
        if [[ -d "$reviewer_dir" ]]; then
            # Send message to reviewer
            "$script_dir/messages" send "@reviewer" "!error" "Trace $trace_id has errors. Review: $meta_file" 2>/dev/null || true
            break
        fi
        scope=$(dirname "$scope")
    done

    # Also notify global orchestrator
    "$script_dir/messages" send "@orchestrator" "!error" "Error in trace $trace_id: $(jq -r '.error_summary' "$meta_file")" 2>/dev/null || true
}

# =============================================================================
# List traces
# =============================================================================

cmd_list() {
    local errors_only=false
    local limit=20

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --errors|-e) errors_only=true ;;
            --limit|-n) limit="$2"; shift ;;
        esac
        shift
    done

    echo -e "${BOLD}Recent Traces${NC}"
    echo

    if [[ ! -f "$TRACES_DIR/index.jsonl" ]]; then
        echo -e "${DIM}  (no traces)${NC}"
        return
    fi

    local filter='.'
    $errors_only && filter='select(.error_detected == true)'

    tail -n "$limit" "$TRACES_DIR/index.jsonl" | jq -r "$filter | \"\(.timestamp | split(\"T\")[1] | split(\".\")[0]) \(.exit_code) \(.id | split(\"-\")[1]) \(.command | .[0:40])\"" 2>/dev/null | \
    while read -r time exit id cmd; do
        local icon="${GREEN}✓${NC}"
        [[ "$exit" != "0" ]] && icon="${RED}✗${NC}"
        echo -e "  $icon ${DIM}$time${NC} $cmd"
        echo -e "    ${DIM}trace-$id${NC}"
    done
}

# =============================================================================
# Show trace details
# =============================================================================

cmd_show() {
    local trace_id="$1"
    [[ -z "$trace_id" ]] && {
        echo "Usage: metasphere trace show TRACE_ID"
        exit 1
    }

    # Find the trace
    local meta=$(grep "\"id\":\"$trace_id\"" "$TRACES_DIR/index.jsonl" 2>/dev/null | tail -1)
    [[ -z "$meta" ]] && {
        echo "Trace not found: $trace_id"
        exit 1
    }

    echo -e "${BOLD}Trace: $trace_id${NC}"
    echo

    echo "$meta" | jq -r '"Timestamp: \(.timestamp)
Agent: \(.agent)
Scope: \(.scope)
Command: \(.command)
Exit Code: \(.exit_code)
Duration: \(.duration_ms)ms
Error: \(.error_detected) (\(.error_type // \"none\"))"'

    echo
    echo -e "${BOLD}stdout:${NC}"
    local stdout_file=$(echo "$meta" | jq -r '.stdout_file')
    [[ -f "$stdout_file" ]] && head -50 "$stdout_file" || echo "(empty)"

    echo
    echo -e "${BOLD}stderr:${NC}"
    local stderr_file=$(echo "$meta" | jq -r '.stderr_file')
    [[ -f "$stderr_file" ]] && head -50 "$stderr_file" || echo "(empty)"
}

# =============================================================================
# Search traces
# =============================================================================

cmd_search() {
    local pattern="$*"
    [[ -z "$pattern" ]] && {
        echo "Usage: metasphere trace search \"pattern\""
        exit 1
    }

    echo -e "${BOLD}Searching traces for: $pattern${NC}"
    echo

    # Search in index
    grep -i "$pattern" "$TRACES_DIR/index.jsonl" 2>/dev/null | jq -r '"\(.id) \(.timestamp) \(.command)"' | head -20

    # Search in stdout/stderr files
    echo
    echo -e "${DIM}In output files:${NC}"
    grep -rl "$pattern" "$TRACES_DIR"/*/  2>/dev/null | head -10 | while read -r file; do
        echo "  $file"
    done
}

# =============================================================================
# Main dispatch
# =============================================================================

case "${1:-}" in
    run|exec)
        shift
        cmd_run "$@"
        ;;
    list|ls)
        shift
        cmd_list "$@"
        ;;
    show|get)
        shift
        cmd_show "$@"
        ;;
    search|find)
        shift
        cmd_search "$@"
        ;;
    *)
        cat << 'EOF'
metasphere-trace - Command trace capture

Usage:
  metasphere trace run "command"      Execute and capture output
  metasphere trace list [--errors]    List recent traces
  metasphere trace show ID            Show trace details
  metasphere trace search "pattern"   Search traces

Options:
  --errors, -e    Show only traces with errors
  --limit, -n N   Limit results (default 20)

Traces are stored in ~/.metasphere/traces/YYYY-MM-DD/
Review agents are notified automatically on errors.
EOF
        exit 1
        ;;
esac
