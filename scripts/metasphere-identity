#!/bin/bash
# metasphere-identity - Resolve current agent identity
#
# Resolution order:
#   1. $METASPHERE_AGENT_ID env var
#   2. ~/.metasphere/current_agent pointer file
#   3. @orchestrator (if ~/.metasphere/agents/@orchestrator exists)
#   4. @user

resolve_agent_id() {
    local metasphere_dir="${METASPHERE_DIR:-$HOME/.metasphere}"

    if [[ -n "$METASPHERE_AGENT_ID" ]]; then
        echo "$METASPHERE_AGENT_ID"
        return
    fi

    if [[ -f "$metasphere_dir/current_agent" ]]; then
        local current
        current=$(cat "$metasphere_dir/current_agent" 2>/dev/null | tr -d '[:space:]')
        if [[ -n "$current" ]]; then
            echo "$current"
            return
        fi
    fi

    if [[ -d "$metasphere_dir/agents/@orchestrator" ]]; then
        echo "@orchestrator"
        return
    fi

    echo "@user"
}

# If sourced, just expose the function. If executed, print resolved id.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    resolve_agent_id
fi
