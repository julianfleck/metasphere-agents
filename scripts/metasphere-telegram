#!/bin/bash
# metasphere-telegram - Telegram bridge for agent communication
#
# Modes:
#   metasphere-telegram poll              # Long-poll for messages (daemon mode)
#   metasphere-telegram send "message"    # Send message to default chat
#   metasphere-telegram notify "message"  # Send notification (for agent escalation)
#   metasphere-telegram webhook <url>     # Set webhook URL
#
# Environment:
#   TELEGRAM_BOT_TOKEN    - Bot token (or loaded from ~/.metasphere/config/telegram.env)
#   TELEGRAM_CHAT_ID      - Default chat ID for notifications
#   METASPHERE_AGENT_ID   - Current agent (for message routing)

set -e

METASPHERE_DIR="${METASPHERE_DIR:-$HOME/.metasphere}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Load token from config if not in environment
if [[ -z "$TELEGRAM_BOT_TOKEN" && -f "$METASPHERE_DIR/config/telegram.env" ]]; then
    source "$METASPHERE_DIR/config/telegram.env"
fi

if [[ -z "$TELEGRAM_BOT_TOKEN" ]]; then
    echo "Error: TELEGRAM_BOT_TOKEN not set"
    echo "Set it in environment or create ~/.metasphere/config/telegram.env"
    exit 1
fi

API_BASE="https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN"

# Load chat ID if saved
CHAT_ID_FILE="$METASPHERE_DIR/config/telegram_chat_id"
if [[ -z "$TELEGRAM_CHAT_ID" && -f "$CHAT_ID_FILE" ]]; then
    TELEGRAM_CHAT_ID=$(cat "$CHAT_ID_FILE")
fi

# Load forum ID if configured
FORUM_ID_FILE="$METASPHERE_DIR/config/telegram_forum_id"
if [[ -f "$FORUM_ID_FILE" ]]; then
    FORUM_CHAT_ID=$(cat "$FORUM_ID_FILE")
fi

# Telegram API call
tg_api() {
    local method="$1"
    shift
    curl -s -X POST "$API_BASE/$method" "$@"
}

# Send a message.
# parse_mode defaults to empty (plain text). Plain text avoids the entire
# class of "Bad Request: can't parse entities" errors that bite when callers
# include parens, asterisks, backticks, etc. Pass "Markdown" or "MarkdownV2"
# explicitly when the caller has actually escaped its content.
# Always uses --data-urlencode so special chars in `text` survive transit.
send_message() {
    local chat_id="$1"
    local text="$2"
    local parse_mode="${3:-}"

    if [[ -n "$parse_mode" ]]; then
        tg_api "sendMessage" \
            -d "chat_id=$chat_id" \
            --data-urlencode "text=$text" \
            -d "parse_mode=$parse_mode"
    else
        tg_api "sendMessage" \
            -d "chat_id=$chat_id" \
            --data-urlencode "text=$text"
    fi
}

# Get updates (long polling)
get_updates() {
    local offset="${1:-0}"
    local timeout="${2:-30}"

    tg_api "getUpdates" \
        -d "offset=$offset" \
        -d "timeout=$timeout" \
        -d "allowed_updates=[\"message\"]"
}

# Process incoming message
# Arguments: chat_id, from_user, text, [message_thread_id]
process_message() {
    local chat_id="$1"
    local from_user="$2"
    local text="$3"
    local thread_id="${4:-}"

    # Save chat ID for future notifications (only for DM, not forum)
    if [[ -z "$thread_id" ]]; then
        echo "$chat_id" > "$CHAT_ID_FILE"
    fi

    # Helper to reply (respects thread_id for forum topics)
    reply() {
        local msg="$1"
        # Truncate to ~3500 chars to stay under Telegram 4096 limit
        if [[ ${#msg} -gt 3500 ]]; then
            msg="${msg:0:3500}
... (truncated)"
        fi
        if [[ -n "$thread_id" ]]; then
            tg_api "sendMessage" \
                -d "chat_id=$chat_id" \
                -d "message_thread_id=$thread_id" \
                --data-urlencode "text=$msg" > /dev/null
        else
            tg_api "sendMessage" \
                -d "chat_id=$chat_id" \
                --data-urlencode "text=$msg" > /dev/null
        fi
    }

    # Reply with a code block (title + preformatted body)
    reply_code() {
        local title="$1"
        local body="$2"
        # Budget: 3500 minus title/fences
        local max=3400
        if [[ ${#body} -gt $max ]]; then
            body="${body:0:$max}
... (truncated)"
        fi
        reply "*$title*

\`\`\`
$body
\`\`\`"
    }

    # Parse commands
    case "$text" in
        /start*)
            reply "*Metasphere*

Commands:
/status - System overview
/tasks - Active tasks
/agents - List agents
/inbox - Messages
/send @agent !label msg - Send to agent
/cam query - Search memory

Or just message me directly."
            ;;

        /status*|/s)
            local status_output
            status_output=$("$SCRIPT_DIR/metasphere" status 2>/dev/null | head -40 || echo "Error getting status")
            reply "$status_output"
            ;;

        /agents*|/a)
            local agents_output=""
            for status_file in "$METASPHERE_DIR/agents"/@*/status; do
                [[ -f "$status_file" ]] || continue
                local agent=$(basename "$(dirname "$status_file")")
                local status=$(cat "$status_file")
                agents_output="$agents_output
• *$agent*: $status"
            done

            if [[ -z "$agents_output" ]]; then
                agents_output="No agents registered."
            fi

            reply "*Agents*
$agents_output"
            ;;

        /inbox*)
            local target="${text#/inbox}"
            target="${target## }"
            target="${target:-@orchestrator}"

            local scope="$METASPHERE_DIR"
            if [[ -f "$METASPHERE_DIR/agents/$target/scope" ]]; then
                scope=$(cat "$METASPHERE_DIR/agents/$target/scope")
            fi

            local inbox_output
            inbox_output=$(METASPHERE_SCOPE="$scope" METASPHERE_AGENT_ID="$target" "$SCRIPT_DIR/messages" 2>/dev/null || echo "No messages")

            reply "*Inbox for $target*

\`\`\`
$inbox_output
\`\`\`"
            ;;

        /tasks*|/t)
            local tasks_output
            tasks_output=$("$SCRIPT_DIR/tasks" 2>/dev/null || echo "No tasks")

            reply "*Tasks*

$tasks_output"
            ;;

        /send\ *)
            local rest="${text#/send }"
            local target=$(echo "$rest" | awk '{print $1}')
            local label=$(echo "$rest" | awk '{print $2}')
            local message=$(echo "$rest" | cut -d' ' -f3-)

            if [[ -z "$target" || -z "$label" || -z "$message" ]]; then
                reply "Usage: /send @target !label message"
            else
                local result
                result=$(METASPHERE_AGENT_ID="@user" "$SCRIPT_DIR/messages" send "$target" "$label" "$message" 2>&1)
                reply "Sent: $result"
            fi
            ;;

        /cam\ *)
            local query="${text#/cam }"
            local cam_output
            cam_output=$(cam search "$query" --limit 5 2>/dev/null || echo "CAM not available")

            reply "*CAM: $query*

\`\`\`
$cam_output
\`\`\`"
            ;;

        /groups*)
            local subcommand="${text#/groups}"
            subcommand="${subcommand## }"

            if [[ -z "$subcommand" ]]; then
                # List topics
                local topics_output
                topics_output=$("$SCRIPT_DIR/metasphere-telegram-groups" list 2>/dev/null || echo "No topics")
                reply "*Forum Topics*

$topics_output

Create: /groups create \"Name\""
            elif [[ "$subcommand" == create\ * ]]; then
                local name="${subcommand#create }"
                name="${name#\"}"
                name="${name%\"}"
                local result
                result=$("$SCRIPT_DIR/metasphere-telegram-groups" create "$name" 2>&1)
                reply "$result"
            else
                reply "Usage: /groups or /groups create \"Name\""
            fi
            ;;

        /link*)
            # Generate a link to the current topic or create a new one
            local name="${text#/link}"
            name="${name## }"

            if [[ -n "$thread_id" ]]; then
                # Already in a topic, show the link
                local chat_clean="${chat_id#-100}"
                reply "Topic link: https://t.me/c/${chat_clean}/${thread_id}"
            elif [[ -n "$name" ]]; then
                # Create topic and return link
                local link
                link=$("$SCRIPT_DIR/metasphere-telegram-groups" workspace "project" "$name" 2>/dev/null)
                if [[ -n "$link" ]]; then
                    reply "Created workspace: [$name]($link)"
                else
                    reply "Could not create workspace. Is forum configured? /groups"
                fi
            else
                reply "Usage: /link \"Project Name\" to create a workspace"
            fi
            ;;

        /help*|/h)
            reply "Commands

Status:
/status /s - System overview
/tasks /t - Active tasks
/agents /a - List agents
/messages /m - Unread messages
/inbox [@agent] - Agent inbox
/events - Recent events
/tree - Agent tree
/spot - Spot health
/ping - pong

Actions:
/send @agent !label msg - Send message
/cam query - Search memory
/groups - Forum topics
/link Name - Create workspace

Or chat directly with @orchestrator"
            ;;

        /ping*)
            reply "pong"
            ;;

        /events*)
            local ev_output
            ev_output=$("$SCRIPT_DIR/metasphere-events" tail 10 2>/dev/null || echo "No events")
            reply_code "Events" "$ev_output"
            ;;

        /tree*)
            local tree_output
            tree_output=$("$SCRIPT_DIR/metasphere-agent" tree 2>/dev/null || echo "No tree")
            reply_code "Agent Tree" "$tree_output"
            ;;

        /messages*|/m)
            local msg_output
            msg_output=$("$SCRIPT_DIR/messages" 2>/dev/null || echo "No messages")
            reply_code "Messages" "$msg_output"
            ;;

        /spot*)
            local host="${METASPHERE_REMOTE_HOST:-}"
            local port="${METASPHERE_REMOTE_PORT:-22}"
            if [ -z "$host" ]; then
                reply_text "METASPHERE_REMOTE_HOST not set"
            else
                local spot_output
                spot_output=$(ssh -p "$port" -o ConnectTimeout=5 -o BatchMode=yes "$host" \
                    "metasphere status 2>/dev/null || echo 'unreachable'" 2>&1 || echo "ssh failed: $?")
                reply_code "Remote" "$spot_output"
            fi
            ;;

        /project*|/p\ *|/p)
            # /project [sub args...] — dispatch to `metasphere project ...`.
            # Also accepts /project_list, /project_show, etc. as aliases for
            # users with cached BotFather autocomplete from before the
            # underscore variants were collapsed.
            local sub_argv=""
            case "$text" in
                /project_list*)  sub_argv="list ${text#/project_list}" ;;
                /project_show*)  sub_argv="show ${text#/project_show}" ;;
                /project_new*)   sub_argv="new ${text#/project_new}" ;;
                /project_wake*)  sub_argv="wake ${text#/project_wake}" ;;
                /project_chat*)  sub_argv="chat ${text#/project_chat}" ;;
                /project*)       sub_argv="${text#/project}" ;;
                /p\ *|/p)        sub_argv="${text#/p}" ;;
            esac
            sub_argv="${sub_argv# }"
            [[ -z "$sub_argv" ]] && sub_argv="list"
            local project_output
            # shellcheck disable=SC2086 — intentional word splitting
            project_output=$("$SCRIPT_DIR/metasphere" project $sub_argv 2>&1 || true)
            [[ -z "$project_output" ]] && project_output="(no output)"
            reply "$project_output"
            ;;

        /*)
            reply "Unknown command. Try /help"
            ;;

        *)
            # Default: route to @orchestrator silently. The bot used to
            # echo "Routed to @orchestrator" as an ack, but the user
            # finds it noisy — receipt is now signalled by an emoji
            # reaction (set in telegram-stream's poll_once), and the
            # actual reply lands when the orchestrator finishes its turn.
            METASPHERE_AGENT_ID="@user" "$SCRIPT_DIR/messages" send "@orchestrator" "!query" "$text" >/dev/null 2>&1 || true
            ;;
    esac
}

# Poll for messages (daemon mode)
cmd_poll() {
    echo "Starting Telegram bridge (polling mode)..."
    echo "Bot: $TELEGRAM_BOT_TOKEN"

    local offset=0

    while true; do
        local response
        response=$(get_updates "$offset" 30)

        # Parse updates
        local updates
        updates=$(echo "$response" | jq -r '.result[]? | @base64' 2>/dev/null)

        for update in $updates; do
            local decoded
            decoded=$(echo "$update" | base64 -d)

            local update_id chat_id from_user text thread_id is_forum
            update_id=$(echo "$decoded" | jq -r '.update_id')
            chat_id=$(echo "$decoded" | jq -r '.message.chat.id')
            from_user=$(echo "$decoded" | jq -r '.message.from.username // .message.from.first_name')
            text=$(echo "$decoded" | jq -r '.message.text // ""')
            thread_id=$(echo "$decoded" | jq -r '.message.message_thread_id // empty')
            is_forum=$(echo "$decoded" | jq -r '.message.chat.is_forum // false')

            if [[ -n "$text" && "$chat_id" != "null" ]]; then
                local location=""
                [[ "$is_forum" == "true" && -n "$thread_id" ]] && location=" [topic:$thread_id]"
                echo "[$(date -u +%H:%M:%S)] $from_user$location: $text"
                process_message "$chat_id" "$from_user" "$text" "$thread_id"
            fi

            offset=$((update_id + 1))
        done
    done
}

# Send notification (for agent escalation)
cmd_notify() {
    local message="$1"
    local agent="${METASPHERE_AGENT_ID:-@system}"

    if [[ -z "$TELEGRAM_CHAT_ID" ]]; then
        echo "Error: No chat ID saved. Send /start to the bot first."
        exit 1
    fi

    send_message "$TELEGRAM_CHAT_ID" "*Notification from $agent*

$message"
}

# Send plain message
cmd_send() {
    local message="$1"

    if [[ -z "$TELEGRAM_CHAT_ID" ]]; then
        echo "Error: No chat ID saved. Send /start to the bot first."
        exit 1
    fi

    send_message "$TELEGRAM_CHAT_ID" "$message"
}

# Get bot info
cmd_info() {
    tg_api "getMe" | jq .
}

# Main dispatch
case "${1:-}" in
    poll)
        cmd_poll
        ;;
    process)
        # Direct slash command dispatch from gateway: process <chat_id> <text>
        shift
        process_message "$1" "gateway" "$2" ""
        ;;
    send)
        shift
        cmd_send "$*"
        ;;
    notify)
        shift
        cmd_notify "$*"
        ;;
    info)
        cmd_info
        ;;
    *)
        cat << 'EOF'
metasphere-telegram - Telegram bridge for agent communication

Usage:
  metasphere-telegram poll              Start polling for messages (daemon)
  metasphere-telegram send "message"    Send message to saved chat
  metasphere-telegram notify "message"  Send agent notification
  metasphere-telegram info              Show bot info

Environment:
  TELEGRAM_BOT_TOKEN    Bot token (or in ~/.metasphere/config/telegram.env)
  TELEGRAM_CHAT_ID      Default chat ID

First, send /start to your bot to register your chat ID.
EOF
        exit 1
        ;;
esac
