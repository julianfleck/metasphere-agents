#!/bin/bash
# tasks - thin wrapper that execs the Python implementation.
#
# Cutover from bash → Python (T2/T3, 2026-04-08).
# Original bash impl preserved at scripts/tasks.bash.bak as fallback.
# To roll back: cp scripts/tasks.bash.bak scripts/tasks
#
# The Python module lives in metasphere/cli/tasks.py and is invoked
# with PYTHONPATH pointing at the repo root (no system install needed).

REPO_ROOT="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
export PYTHONPATH="${REPO_ROOT}${PYTHONPATH:+:$PYTHONPATH}"
exec python3 -m metasphere.cli.tasks "$@"
