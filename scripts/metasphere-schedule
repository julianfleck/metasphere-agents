#!/bin/bash
# metasphere-schedule - Scheduling system for commands and messages
#
# Usage:
#   metasphere schedule list                           List all scheduled jobs
#   metasphere schedule add "cmd" @TIME [@REPEAT]      Schedule a command
#   metasphere schedule remove ID                      Remove a scheduled job
#   metasphere schedule run                            Run due jobs (called by cron)
#
# Time formats:
#   @15:00          At 15:00 today (or tomorrow if past)
#   @tomorrow       Tomorrow at current time
#   @in:30m         In 30 minutes
#   @in:2h          In 2 hours
#
# Repeat formats:
#   @daily          Every day
#   @hourly         Every hour
#   @weekly         Every week
#   @every:15m      Every 15 minutes
#
# Examples:
#   metasphere schedule add 'send @researcher !task "Review PRs"' @09:00 @daily
#   metasphere schedule add 'gateway poll' @every:5m
#   metasphere schedule add 'status' @in:1h

set -e

METASPHERE_DIR="${METASPHERE_DIR:-$HOME/.metasphere}"
SCHEDULE_DIR="$METASPHERE_DIR/schedule"
SCHEDULE_FILE="$SCHEDULE_DIR/jobs.json"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

mkdir -p "$SCHEDULE_DIR"
[[ -f "$SCHEDULE_FILE" ]] || echo '[]' > "$SCHEDULE_FILE"

# Colors
if [[ -t 1 ]]; then
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    CYAN='\033[0;36m'
    DIM='\033[2m'
    NC='\033[0m'
else
    GREEN='' YELLOW='' CYAN='' DIM='' NC=''
fi

# Generate job ID
gen_id() {
    echo "job-$(date +%s)-$$"
}

# Parse time specification to Unix timestamp
parse_time() {
    local spec="$1"
    local now=$(date +%s)

    case "$spec" in
        @in:*m)
            local mins="${spec#@in:}"
            mins="${mins%m}"
            echo $((now + mins * 60))
            ;;
        @in:*h)
            local hours="${spec#@in:}"
            hours="${hours%h}"
            echo $((now + hours * 3600))
            ;;
        @tomorrow)
            echo $((now + 86400))
            ;;
        @[0-9][0-9]:[0-9][0-9])
            local time="${spec#@}"
            local target=$(date -j -f "%Y-%m-%d %H:%M" "$(date +%Y-%m-%d) $time" +%s 2>/dev/null || \
                          date -d "$(date +%Y-%m-%d) $time" +%s 2>/dev/null)
            # If past, schedule for tomorrow
            if [[ $target -le $now ]]; then
                target=$((target + 86400))
            fi
            echo "$target"
            ;;
        *)
            # Default: now
            echo "$now"
            ;;
    esac
}

# Parse repeat specification to seconds
parse_repeat() {
    local spec="$1"

    case "$spec" in
        @hourly)
            echo 3600
            ;;
        @daily)
            echo 86400
            ;;
        @weekly)
            echo 604800
            ;;
        @every:*m)
            local mins="${spec#@every:}"
            mins="${mins%m}"
            echo $((mins * 60))
            ;;
        @every:*h)
            local hours="${spec#@every:}"
            hours="${hours%h}"
            echo $((hours * 3600))
            ;;
        *)
            echo 0
            ;;
    esac
}

# List scheduled jobs
cmd_list() {
    echo -e "${CYAN}Scheduled Jobs${NC}"
    echo

    local jobs=$(cat "$SCHEDULE_FILE")
    local count=$(echo "$jobs" | jq 'length')

    if [[ "$count" == "0" ]]; then
        echo -e "${DIM}  (no scheduled jobs)${NC}"
        return
    fi

    # New cron-format jobs (kind=cron) are listed first, then legacy interval jobs.
    echo "$jobs" | jq -r '
        .[] |
        if (.kind // "interval") == "cron" then
            [
                .id,
                "cron",
                .cron_expr,
                .tz,
                ("[" + (.agent_id // "main") + "] " + (.name // "unnamed")),
                (.enabled | tostring),
                ((.last_fired_at // 0) | tostring)
            ] | @tsv
        else
            [
                .id,
                "interval",
                ((.next_run // 0) | tonumber | strftime("%Y-%m-%d %H:%M")),
                "",
                (.command // ""),
                ((.enabled // true) | tostring),
                "0"
            ] | @tsv
        end
    ' | sort -k2 | while IFS=$'\t' read -r id kind a b cmd enabled last_fired; do
        local en=""
        if [[ "$enabled" == "false" ]]; then
            en="${DIM}(disabled)${NC} "
        fi
        if [[ "$kind" == "cron" ]]; then
            echo -e "  ${DIM}$id${NC}"
            echo -e "    ${GREEN}[cron]${NC} $en$cmd"
            echo -e "    ${DIM}Expr: $a ($b)${NC}"
            if [[ "$last_fired" != "0" ]]; then
                local lf
                lf=$(date -r "$last_fired" "+%Y-%m-%d %H:%M" 2>/dev/null || date -d "@$last_fired" "+%Y-%m-%d %H:%M" 2>/dev/null || echo "?")
                echo -e "    ${DIM}Last fired: $lf${NC}"
            fi
        else
            echo -e "  ${DIM}$id${NC}"
            echo -e "    $en$cmd"
            echo -e "    ${DIM}Next: $a${NC}"
        fi
        echo
    done
}

# Add a scheduled job
cmd_add() {
    local cmd="$1"
    local time_spec="${2:-@in:1m}"
    local repeat_spec="${3:-}"

    if [[ -z "$cmd" ]]; then
        echo "Usage: metasphere schedule add 'command' @TIME [@REPEAT]"
        echo
        echo "Time:"
        echo "  @15:00      At 15:00"
        echo "  @in:30m     In 30 minutes"
        echo "  @in:2h      In 2 hours"
        echo "  @tomorrow   Tomorrow"
        echo
        echo "Repeat:"
        echo "  @hourly     Every hour"
        echo "  @daily      Every day"
        echo "  @weekly     Every week"
        echo "  @every:15m  Every 15 minutes"
        exit 1
    fi

    local id=$(gen_id)
    local next_run=$(parse_time "$time_spec")
    local repeat_secs=$(parse_repeat "$repeat_spec")
    local repeat_human="once"
    [[ $repeat_secs -gt 0 ]] && repeat_human="${repeat_spec#@}"

    # Expand command shortcuts
    local full_cmd="$cmd"
    case "$cmd" in
        send\ *)
            full_cmd="$SCRIPT_DIR/messages ${cmd}"
            ;;
        status|ls|agents)
            full_cmd="$SCRIPT_DIR/metasphere $cmd"
            ;;
        gateway\ *)
            full_cmd="$SCRIPT_DIR/metasphere-gateway ${cmd#gateway }"
            ;;
    esac

    # Add to schedule
    local job=$(jq -n \
        --arg id "$id" \
        --arg cmd "$full_cmd" \
        --arg orig "$cmd" \
        --argjson next "$next_run" \
        --argjson repeat "$repeat_secs" \
        --arg repeat_human "$repeat_human" \
        '{id: $id, command: $orig, full_command: $cmd, next_run: $next, repeat_secs: $repeat, repeat_human: $repeat_human, created: now}')

    local jobs=$(cat "$SCHEDULE_FILE")
    echo "$jobs" | jq --argjson job "$job" '. + [$job]' > "$SCHEDULE_FILE"

    echo -e "${GREEN}Scheduled${NC}: $id"
    echo "  Command: $cmd"
    echo "  Next run: $(date -r "$next_run" "+%Y-%m-%d %H:%M" 2>/dev/null || date -d "@$next_run" "+%Y-%m-%d %H:%M")"
    [[ "$repeat_human" != "once" ]] && echo "  Repeat: $repeat_human"
}

# Remove a scheduled job
cmd_remove() {
    local id="$1"

    if [[ -z "$id" ]]; then
        echo "Usage: metasphere schedule remove JOB_ID"
        exit 1
    fi

    local jobs=$(cat "$SCHEDULE_FILE")
    local new_jobs=$(echo "$jobs" | jq --arg id "$id" '[.[] | select(.id != $id)]')

    if [[ "$jobs" == "$new_jobs" ]]; then
        echo "Job not found: $id"
        exit 1
    fi

    echo "$new_jobs" > "$SCHEDULE_FILE"
    echo -e "${GREEN}Removed${NC}: $id"
}

# Should a cron-format job fire right now? Returns 0 (yes) or 1 (no).
# Uses Python + croniter if available (most reliable), else falls back to a
# small bash matcher that handles `*`, `*/N`, comma lists, ranges, and exact
# values for the standard 5 cron fields. Does NOT handle full cron syntax
# like @reboot or named months.
cron_should_fire() {
    local expr="$1"
    local tz="${2:-UTC}"
    local last_fired_at="${3:-0}"
    local now_epoch
    now_epoch=$(date +%s)

    # Don't fire twice in the same minute
    local elapsed=$((now_epoch - last_fired_at))
    [[ $elapsed -lt 60 ]] && return 1

    # Try Python + croniter first (most accurate, handles tz + DST)
    if command -v python3 >/dev/null 2>&1; then
        local result
        result=$(python3 - "$expr" "$tz" "$last_fired_at" 2>/dev/null <<'PY'
import sys
try:
    from croniter import croniter
except ImportError:
    sys.exit(2)  # signal "no croniter"
import datetime
try:
    from zoneinfo import ZoneInfo
except ImportError:
    sys.exit(2)

expr = sys.argv[1]
tz = sys.argv[2]
last = int(sys.argv[3] or 0)

try:
    zone = ZoneInfo(tz)
except Exception:
    zone = ZoneInfo("UTC")

now = datetime.datetime.now(tz=zone)
# croniter gives us "what's the most recent fire time at or before now?"
itr = croniter(expr, now)
prev = itr.get_prev(datetime.datetime)
prev_epoch = int(prev.timestamp())

# Fire if the most recent expected fire time is within the last 180 seconds
# AND we haven't already fired since then. (180s window protects against
# scheduler tick drift, restarts, and briefly-paused daemons. The 90s
# window we used previously was too tight: a single missed tick during a
# patch/restart would silently skip the job for that interval.)
import time
delta = int(time.time()) - prev_epoch
if 0 <= delta < 180 and prev_epoch > last:
    sys.exit(0)
sys.exit(1)
PY
        )
        local rc=$?
        # rc=0 → fire, rc=1 → don't fire, rc=2 → croniter not installed (fallback)
        if [[ $rc -eq 0 || $rc -eq 1 ]]; then
            return $rc
        fi
    fi

    # Bash fallback: parse 5 fields, check current time. tz is honored via
    # `TZ=` env on the date call so weekday/hour are local-time-correct.
    local cur_min cur_hour cur_dom cur_mon cur_dow
    cur_min=$(TZ="$tz" date +%-M)
    cur_hour=$(TZ="$tz" date +%-H)
    cur_dom=$(TZ="$tz" date +%-d)
    cur_mon=$(TZ="$tz" date +%-m)
    cur_dow=$(TZ="$tz" date +%-w)  # 0=Sun

    read -r f_min f_hour f_dom f_mon f_dow <<<"$expr"
    [[ -z "$f_dow" ]] && return 1  # malformed

    _cron_field_match "$f_min" "$cur_min" 0 59 || return 1
    _cron_field_match "$f_hour" "$cur_hour" 0 23 || return 1
    _cron_field_match "$f_dom" "$cur_dom" 1 31 || return 1
    _cron_field_match "$f_mon" "$cur_mon" 1 12 || return 1
    _cron_field_match "$f_dow" "$cur_dow" 0 6 || return 1

    return 0
}

# Match a single cron field against a current numeric value.
# Supports: `*`, `N`, `N-M`, `*/N`, `N,M,...`
_cron_field_match() {
    local field="$1"
    local value="$2"
    local min="$3"
    local max="$4"

    # Comma list — match any
    if [[ "$field" == *,* ]]; then
        local IFS=','
        local -a parts
        # shellcheck disable=SC2206
        parts=($field)
        for p in "${parts[@]}"; do
            _cron_field_match "$p" "$value" "$min" "$max" && return 0
        done
        return 1
    fi

    case "$field" in
        \*)  return 0 ;;
        \*/*)
            local step="${field#*/}"
            (( value % step == 0 )) && return 0 || return 1
            ;;
        *-*)
            local lo="${field%-*}" hi="${field#*-}"
            (( value >= lo && value <= hi )) && return 0 || return 1
            ;;
        *)
            (( value == field )) && return 0 || return 1
            ;;
    esac
}

# Run due jobs (handles both legacy `repeat_secs` jobs and new `kind=cron` jobs)
cmd_run() {
    local now=$(date +%s)
    local jobs=$(cat "$SCHEDULE_FILE")
    local updated_jobs="[]"

    # Use process substitution instead of a pipe so the while-loop runs in
    # the parent shell and `updated_jobs` mutations actually persist.
    # Previously this used `echo "$jobs" | jq ... | while read`, which put
    # the loop body in a subshell — every cmd_run wiped the schedule file
    # to "[]" because the parent's $updated_jobs never got updated.
    while read -r job; do
        local id=$(echo "$job" | jq -r '.id')
        local kind=$(echo "$job" | jq -r '.kind // "interval"')
        local enabled=$(echo "$job" | jq -r '.enabled // true')

        # Skip disabled jobs (preserved in file but not run)
        if [[ "$enabled" == "false" ]]; then
            updated_jobs=$(echo "$updated_jobs" | jq --argjson job "$job" '. + [$job]')
            continue
        fi

        local should_run=false
        local orig_cmd=$(echo "$job" | jq -r '.command // ""')

        if [[ "$kind" == "cron" ]]; then
            # New schema: raw cron expression + tz + named agent payload
            local cron_expr=$(echo "$job" | jq -r '.cron_expr')
            local tz=$(echo "$job" | jq -r '.tz // "UTC"')
            local last_fired=$(echo "$job" | jq -r '.last_fired_at // 0')

            if cron_should_fire "$cron_expr" "$tz" "$last_fired"; then
                should_run=true
                # Update last_fired_at to prevent re-firing this minute
                job=$(echo "$job" | jq --argjson now "$now" '.last_fired_at = $now')
            fi

            # For cron jobs, the command we actually execute is "spawn the
            # named agent with the payload message as its task"
            local agent_id=$(echo "$job" | jq -r '.agent_id // "main"')
            local payload=$(echo "$job" | jq -r '.payload_message // ""')
            local name=$(echo "$job" | jq -r '.name // "unnamed"')
            # Truncate payload for display
            local payload_summary=${payload:0:80}
            orig_cmd="[cron] @$agent_id: $name"

            if $should_run; then
                echo "[$(TZ=$tz date +%Y-%m-%dT%H:%M:%S)] Firing cron job: $orig_cmd"
                # Log to events
                "$SCRIPT_DIR/metasphere-events" log schedule.cron_fire "$name" --agent "@$agent_id" 2>/dev/null || true

                # The job's agent_id should usually point at a *persistent
                # collaborator* — the openclaw migration left them all as
                # @main, but mission-writer split them into named persistent
                # agents (@briefing, @polymarket, @research-*, etc.) based
                # on the job name's role prefix. Resolve agent_id → real
                # persistent agent by extracting the prefix from the job
                # name (e.g. "research-monitor:brand-mentions" → @research-brand-mentions,
                # "polymarket:trading-run" → @polymarket).
                local target_agent="@$agent_id"
                case "$name" in
                    research-monitor:*)
                        target_agent="@research-${name#research-monitor:}"
                        ;;
                    polymarket:*) target_agent="@polymarket" ;;
                    spot:autonomous-exploration*) target_agent="@explorer" ;;
                    rage-changelog*) target_agent="@rage-changelog" ;;
                    "Morning briefing"*) target_agent="@briefing" ;;
                esac

                # If the resolved agent has a MISSION.md, use metasphere-wake
                # (start its tmux+REPL, inject the payload as a task). Otherwise
                # fall back to the old spawn-headless path.
                if [[ -f "$METASPHERE_DIR/agents/$target_agent/MISSION.md" ]]; then
                    "$SCRIPT_DIR/metasphere-wake" "$target_agent" "$payload" 2>&1 | head -5 || true
                elif ! "$SCRIPT_DIR/metasphere-agent" status "$target_agent" >/dev/null 2>&1; then
                    "$SCRIPT_DIR/metasphere-spawn" "$target_agent" "/" "$payload" "@orchestrator" 2>&1 | head -3 || true
                else
                    "$SCRIPT_DIR/messages" send "$target_agent" "!task" "$payload" 2>&1 | head -3 || true
                fi
            fi
        else
            # Legacy interval/once schema
            local next_run=$(echo "$job" | jq -r '.next_run')
            local repeat_secs=$(echo "$job" | jq -r '.repeat_secs')
            local full_cmd=$(echo "$job" | jq -r '.full_command')

            if [[ $next_run -le $now ]]; then
                should_run=true
                echo "[$(date -u +%H:%M:%S)] Running: $orig_cmd"
                eval "$full_cmd" 2>&1 | head -20 || true

                if [[ $repeat_secs -gt 0 ]]; then
                    local new_next=$((now + repeat_secs))
                    job=$(echo "$job" | jq --argjson next "$new_next" '.next_run = $next')
                else
                    job=$(echo "$job" | jq '.done = true')
                fi
            fi
        fi

        # Keep non-done jobs
        if [[ $(echo "$job" | jq -r '.done // false') != "true" ]]; then
            updated_jobs=$(echo "$updated_jobs" | jq --argjson job "$job" '. + [$job]')
        fi
    done < <(echo "$jobs" | jq -c '.[]')

    # Defensive: if updated_jobs is empty array AND original was not, do
    # NOT overwrite. This guards against any future bug that might silently
    # truncate the file.
    local input_count
    input_count=$(echo "$jobs" | jq 'length' 2>/dev/null || echo 0)
    local output_count
    output_count=$(echo "$updated_jobs" | jq 'length' 2>/dev/null || echo 0)
    if [[ "$input_count" -gt 0 && "$output_count" -eq 0 ]]; then
        echo "[$(date -u +%H:%M:%S)] WARN: cmd_run would have wiped $input_count jobs to 0; refusing write" >&2
        return 1
    fi

    echo "$updated_jobs" > "$SCHEDULE_FILE"
}

# Daemon mode - check every minute
cmd_daemon() {
    local interval="${1:-60}"
    echo "Schedule daemon started (check interval: ${interval}s)"

    while true; do
        cmd_run 2>/dev/null
        sleep "$interval"
    done
}

# Quick schedule message to agent
cmd_message() {
    local target="$1"
    local label="$2"
    local msg="$3"
    local time_spec="${4:-@in:1m}"
    local repeat_spec="${5:-}"

    if [[ -z "$target" || -z "$label" || -z "$msg" ]]; then
        echo "Usage: metasphere schedule message @target !label 'msg' @TIME [@REPEAT]"
        exit 1
    fi

    cmd_add "send $target $label \"$msg\"" "$time_spec" "$repeat_spec"
}

# Main dispatch
case "${1:-}" in
    list|ls|"")
        cmd_list
        ;;
    add|new)
        shift
        cmd_add "$@"
        ;;
    remove|rm|delete)
        shift
        cmd_remove "$@"
        ;;
    run|check)
        cmd_run
        ;;
    daemon)
        shift
        cmd_daemon "$@"
        ;;
    message|msg)
        shift
        cmd_message "$@"
        ;;
    *)
        cat << 'EOF'
metasphere-schedule - Job scheduling for agents

Usage:
  metasphere schedule                           List scheduled jobs
  metasphere schedule add 'cmd' @TIME [@REPEAT] Add a job
  metasphere schedule remove ID                 Remove a job
  metasphere schedule run                       Execute due jobs
  metasphere schedule daemon [N]                Run scheduler daemon

Time formats:
  @15:00          At 15:00 today
  @in:30m         In 30 minutes
  @in:2h          In 2 hours
  @tomorrow       Tomorrow

Repeat formats:
  @hourly         Every hour
  @daily          Every day
  @weekly         Every week
  @every:15m      Every 15 minutes

Examples:
  metasphere schedule add 'send @researcher !task "Review code"' @09:00 @daily
  metasphere schedule add 'status' @in:1h
  metasphere schedule add 'gateway poll' @every:5m
EOF
        exit 1
        ;;
esac
