#!/bin/bash
# metasphere-project - Project management
#
# Projects are the primary organizing unit:
#   - Directory with .metasphere/ marker
#   - Contains tasks, agents, changelogs
#   - Learnings bubble up from agents
#
# Usage:
#   metasphere project init [path]       Initialize project
#   metasphere project list              List all projects
#   metasphere project status [name]     Project status
#   metasphere project changelog [name]  Generate changelog
#   metasphere project learnings [name]  Aggregate learnings

set -e

METASPHERE_DIR="${METASPHERE_DIR:-$HOME/.metasphere}"
PROJECTS_FILE="$METASPHERE_DIR/projects.json"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

mkdir -p "$METASPHERE_DIR"
[[ -f "$PROJECTS_FILE" ]] || echo '[]' > "$PROJECTS_FILE"

# =============================================================================
# Initialize project
# =============================================================================

cmd_init() {
    local path="${1:-.}"
    path=$(cd "$path" && pwd)
    local name=$(basename "$path")

    mkdir -p "$path/.metasphere"
    mkdir -p "$path/.tasks/active" "$path/.tasks/completed"
    mkdir -p "$path/.messages/inbox" "$path/.messages/outbox"
    mkdir -p "$path/.changelog"
    mkdir -p "$path/.learnings"

    # Project config
    if [[ ! -f "$path/.metasphere/project.json" ]]; then
        jq -n \
            --arg name "$name" \
            --arg path "$path" \
            --arg created "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            '{name: $name, path: $path, created: $created, status: "active"}' \
            > "$path/.metasphere/project.json"
    fi

    # Register globally
    local projects=$(cat "$PROJECTS_FILE")
    if ! echo "$projects" | jq -e --arg path "$path" '.[] | select(.path == $path)' > /dev/null 2>&1; then
        echo "$projects" | jq --arg name "$name" --arg path "$path" \
            '. + [{name: $name, path: $path, registered: now}]' > "$PROJECTS_FILE"
    fi

    # Log event
    "$SCRIPT_DIR/metasphere-events" log project.init "Initialized project: $name" --agent @system --meta path="$path" 2>/dev/null || true

    echo "Initialized project: $name"
    echo "  Path: $path"
}

# =============================================================================
# List projects
# =============================================================================

cmd_list() {
    local format="${1:-}"

    if [[ "$format" == "--json" ]]; then
        cat "$PROJECTS_FILE"
        return
    fi

    local projects=$(cat "$PROJECTS_FILE")
    local count=$(echo "$projects" | jq 'length')

    if [[ "$count" == "0" ]]; then
        echo "(no projects)"
        echo "Initialize one: metasphere project init /path/to/project"
        return
    fi

    echo "$projects" | jq -r '.[] | "\(.name)\t\(.path)"' | while IFS=$'\t' read -r name path; do
        # Check if project still exists
        if [[ -d "$path/.metasphere" ]]; then
            # Get task count
            local tasks=$(find "$path/.tasks/active" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
            # Get recent activity
            local recent=""
            if [[ -f "$path/.metasphere/project.json" ]]; then
                recent=$(jq -r '.status // "active"' "$path/.metasphere/project.json")
            fi
            echo "$name ($tasks tasks) - $recent"
            echo "  $path"
        else
            echo "$name (missing)"
            echo "  $path"
        fi
    done
}

# =============================================================================
# Project status
# =============================================================================

cmd_status() {
    local name="$1"
    local path=""

    # Find project
    if [[ -n "$name" ]]; then
        path=$(jq -r --arg name "$name" '.[] | select(.name == $name) | .path' "$PROJECTS_FILE")
    else
        # Current directory
        path=$(pwd)
        while [[ "$path" != "/" ]]; do
            [[ -d "$path/.metasphere" ]] && break
            path=$(dirname "$path")
        done
    fi

    if [[ -z "$path" || ! -d "$path/.metasphere" ]]; then
        echo "Project not found"
        exit 1
    fi

    name=$(basename "$path")

    echo "Project: $name"
    echo "Path: $path"
    echo

    # Tasks
    echo "Tasks:"
    local active=$(find "$path/.tasks/active" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
    local completed=$(find "$path/.tasks/completed" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
    echo "  $active active, $completed completed"

    # Agents scoped to this project
    echo
    echo "Agents:"
    for agent_dir in "$METASPHERE_DIR/agents"/@*/; do
        [[ -d "$agent_dir" ]] || continue
        local scope=$(cat "$agent_dir/scope" 2>/dev/null || echo "")
        if [[ "$scope" == "$path"* ]]; then
            local agent=$(basename "$agent_dir")
            local status=$(cat "$agent_dir/status" 2>/dev/null || echo "?")
            echo "  $agent: $status"
        fi
    done

    # Recent changelog
    echo
    echo "Recent changes:"
    if [[ -d "$path/.changelog" ]]; then
        ls -t "$path/.changelog"/*.md 2>/dev/null | head -3 | while read -r f; do
            echo "  $(basename "$f")"
        done
    else
        echo "  (none)"
    fi
}

# =============================================================================
# Generate changelog from events and commits
# =============================================================================

cmd_changelog() {
    local name="$1"
    local since="${2:-1d}"
    local path=""

    # Find project
    if [[ -n "$name" && "$name" != --* ]]; then
        path=$(jq -r --arg name "$name" '.[] | select(.name == $name) | .path' "$PROJECTS_FILE")
    else
        path=$(pwd)
        while [[ "$path" != "/" ]]; do
            [[ -d "$path/.metasphere" ]] && break
            path=$(dirname "$path")
        done
        [[ "$name" == --since=* ]] && since="${name#--since=}"
    fi

    if [[ -z "$path" || ! -d "$path/.metasphere" ]]; then
        echo "Project not found"
        exit 1
    fi

    name=$(basename "$path")
    local changelog_file="$path/.changelog/$(date +%Y-%m-%d).md"
    mkdir -p "$path/.changelog"

    echo "# Changelog - $(date +%Y-%m-%d)"
    echo
    echo "Project: $name"
    echo

    # Git commits
    if [[ -d "$path/.git" ]]; then
        echo "## Commits"
        echo
        cd "$path"
        git log --oneline --since="$since" 2>/dev/null | head -20 | while read -r line; do
            echo "- $line"
        done
        echo
    fi

    # Task completions from events
    echo "## Tasks Completed"
    echo
    if [[ -f "$METASPHERE_DIR/events/events.jsonl" ]]; then
        grep '"type":"task.complete"' "$METASPHERE_DIR/events/events.jsonl" 2>/dev/null | \
            jq -r 'select(.meta.scope // "" | startswith("'"$path"'")) | "- \(.message)"' 2>/dev/null | head -10
    fi
    echo

    # Agent activity
    echo "## Agent Activity"
    echo
    for agent_dir in "$METASPHERE_DIR/agents"/@*/; do
        [[ -d "$agent_dir" ]] || continue
        local scope=$(cat "$agent_dir/scope" 2>/dev/null || echo "")
        if [[ "$scope" == "$path"* ]]; then
            local agent=$(basename "$agent_dir")
            local status=$(cat "$agent_dir/status" 2>/dev/null || echo "?")
            echo "- $agent: $status"
        fi
    done
}

# =============================================================================
# Aggregate learnings from all agents in project
# =============================================================================

cmd_learnings() {
    local name="$1"
    local path=""

    # Find project
    if [[ -n "$name" ]]; then
        path=$(jq -r --arg name "$name" '.[] | select(.name == $name) | .path' "$PROJECTS_FILE")
    else
        path=$(pwd)
        while [[ "$path" != "/" ]]; do
            [[ -d "$path/.metasphere" ]] && break
            path=$(dirname "$path")
        done
    fi

    if [[ -z "$path" || ! -d "$path/.metasphere" ]]; then
        echo "Project not found"
        exit 1
    fi

    name=$(basename "$path")
    local learnings_file="$path/.learnings/aggregated-$(date +%Y-%m-%d).md"
    mkdir -p "$path/.learnings"

    echo "# Learnings - $name"
    echo "Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo

    # Collect from agents scoped to this project
    for agent_dir in "$METASPHERE_DIR/agents"/@*/; do
        [[ -d "$agent_dir" ]] || continue
        local scope=$(cat "$agent_dir/scope" 2>/dev/null || echo "")

        if [[ "$scope" == "$path"* && -d "$agent_dir/learnings" ]]; then
            local agent=$(basename "$agent_dir")
            local has_learnings=false

            for learning in "$agent_dir/learnings"/*.md; do
                [[ -f "$learning" ]] || continue
                has_learnings=true

                if ! $has_learnings; then
                    echo "## $agent"
                    echo
                fi

                echo "### $(basename "$learning" .md)"
                echo
                cat "$learning"
                echo
            done
        fi
    done

    # Also check project-level learnings
    if [[ -d "$path/.learnings" ]]; then
        echo "## Project-level"
        echo
        for learning in "$path/.learnings"/*.md; do
            [[ -f "$learning" && "$learning" != *aggregated* ]] || continue
            echo "### $(basename "$learning" .md)"
            cat "$learning"
            echo
        done
    fi
}

# =============================================================================
# Main dispatch
# =============================================================================

case "${1:-}" in
    init|new)
        shift
        cmd_init "$@"
        ;;
    list|ls)
        shift
        cmd_list "$@"
        ;;
    status|show)
        shift
        cmd_status "$@"
        ;;
    changelog|changes)
        shift
        cmd_changelog "$@"
        ;;
    learnings|learn)
        shift
        cmd_learnings "$@"
        ;;
    *)
        cat << 'EOF'
metasphere-project - Project management

Usage:
  metasphere project init [path]        Initialize project in directory
  metasphere project list               List all projects
  metasphere project status [name]      Show project status
  metasphere project changelog [name]   Generate changelog
  metasphere project learnings [name]   Aggregate learnings from agents

Projects are directories with .metasphere/ containing:
  .tasks/          Active and completed tasks
  .messages/       Agent communication
  .changelog/      Generated changelogs
  .learnings/      Aggregated learnings

Learnings bubble up from:
  Agent sunset reports → Project learnings → Global knowledge
EOF
        exit 1
        ;;
esac
