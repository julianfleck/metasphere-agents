#!/bin/bash
# metasphere-telegram-stream - Archive Telegram messages and feed to CAM
#
# Maintains a local archive of all Telegram messages at:
#   ~/.metasphere/telegram/stream/YYYY-MM-DD.jsonl
#   ~/.metasphere/telegram/latest.json  (most recent message for context injection)
#
# Also indexes messages into CAM for searchable history.
#
# Usage:
#   metasphere-telegram-stream daemon [interval]  # Run continuously (default 5s)
#   metasphere-telegram-stream once               # Single poll
#   metasphere-telegram-stream latest             # Show latest message
#   metasphere-telegram-stream context            # Format latest for agent context

set -e

METASPHERE_DIR="${METASPHERE_DIR:-$HOME/.metasphere}"
TELEGRAM_DIR="$METASPHERE_DIR/telegram"
STREAM_DIR="$TELEGRAM_DIR/stream"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

mkdir -p "$STREAM_DIR"

# Load config
if [[ -f "$METASPHERE_DIR/config/telegram.env" ]]; then
    source "$METASPHERE_DIR/config/telegram.env"
fi

OFFSET_FILE="$TELEGRAM_DIR/offset"
LATEST_FILE="$TELEGRAM_DIR/latest.json"
CHAT_ID_FILE="$METASPHERE_DIR/config/telegram_chat_id"

# Get current offset
get_offset() {
    [[ -f "$OFFSET_FILE" ]] && cat "$OFFSET_FILE" || echo "0"
}

# Save offset
save_offset() {
    echo "$1" > "$OFFSET_FILE"
}

# Archive a message to daily JSONL file
archive_message() {
    local msg_json="$1"
    local date_str=$(date -u +%Y-%m-%d)
    local archive_file="$STREAM_DIR/${date_str}.jsonl"

    echo "$msg_json" >> "$archive_file"
}

# Index message into CAM
index_to_cam() {
    local msg_json="$1"

    # Extract fields
    local from=$(echo "$msg_json" | jq -r '.from.username // .from.first_name // "unknown"')
    local text=$(echo "$msg_json" | jq -r '.text // ""')
    local date=$(echo "$msg_json" | jq -r '.date')
    local chat_id=$(echo "$msg_json" | jq -r '.chat.id')

    [[ -z "$text" || "$text" == "null" ]] && return

    # Format for CAM indexing
    local timestamp=$(date -u -r "$date" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)

    # Create a session-like format for CAM
    local cam_content="[Telegram @$from $timestamp]
$text"

    # Index via CAM if available
    if command -v cam &>/dev/null; then
        echo "$cam_content" | cam index --source "telegram" --agent "@$from" 2>/dev/null || true
    fi
}

# Save as latest (for context injection)
save_latest() {
    local msg_json="$1"
    echo "$msg_json" | jq '{
        message_id: .message_id,
        from: (.from.username // .from.first_name),
        text: .text,
        date: .date,
        timestamp: (now | strftime("%Y-%m-%dT%H:%M:%SZ")),
        chat_id: .chat.id
    }' > "$LATEST_FILE"
}

# Poll for new messages
poll_once() {
    [[ -z "$TELEGRAM_BOT_TOKEN" ]] && {
        echo "Error: TELEGRAM_BOT_TOKEN not set"
        return 1
    }

    local offset=$(get_offset)
    local response

    response=$(curl -s "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/getUpdates?offset=$offset&timeout=1")

    local ok=$(echo "$response" | jq -r '.ok')
    [[ "$ok" != "true" ]] && {
        echo "API error: $(echo "$response" | jq -r '.description')"
        return 1
    }

    # Process each update
    echo "$response" | jq -c '.result[]' 2>/dev/null | while read -r update; do
        local update_id=$(echo "$update" | jq -r '.update_id')
        local message=$(echo "$update" | jq -c '.message // empty')

        if [[ -n "$message" && "$message" != "null" ]]; then
            local chat_id=$(echo "$message" | jq -r '.chat.id')
            local from=$(echo "$message" | jq -r '.from.username // .from.first_name')
            local text=$(echo "$message" | jq -r '.text // "[non-text]"')

            echo "[$(date -u +%H:%M:%S)] @$from: $text"

            # Save chat ID
            echo "$chat_id" > "$CHAT_ID_FILE"

            # Archive
            archive_message "$message"

            # Save as latest
            save_latest "$message"

            # Index to CAM
            index_to_cam "$message"

            # Process commands (delegate to telegram script)
            if [[ "$text" == /* ]]; then
                "$SCRIPT_DIR/metasphere-telegram" process "$chat_id" "$text" 2>/dev/null &
            fi
        fi

        # Update offset
        save_offset $((update_id + 1))
    done
}

# Get latest message for context
get_latest() {
    if [[ -f "$LATEST_FILE" ]]; then
        cat "$LATEST_FILE"
    else
        echo '{"text": null, "from": null}'
    fi
}

# Format latest for agent context injection
format_context() {
    local history_count=1

    # Parse --history N argument
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --history|-h)
                history_count="${2:-5}"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    # Get today's archive file
    local today=$(date -u +%Y-%m-%d)
    local archive_file="$STREAM_DIR/${today}.jsonl"

    # Also check yesterday for continuity
    local yesterday=$(date -u -v-1d +%Y-%m-%d 2>/dev/null || date -u -d "yesterday" +%Y-%m-%d 2>/dev/null)
    local yesterday_file="$STREAM_DIR/${yesterday}.jsonl"

    # Collect recent messages
    local messages=""
    if [[ -f "$archive_file" ]]; then
        messages=$(tail -n "$history_count" "$archive_file" 2>/dev/null)
    fi

    # If not enough messages today, get some from yesterday
    local msg_count=$(echo "$messages" | grep -c '.' 2>/dev/null || echo 0)
    if [[ $msg_count -lt $history_count && -f "$yesterday_file" ]]; then
        local need=$((history_count - msg_count))
        local yesterday_msgs=$(tail -n "$need" "$yesterday_file" 2>/dev/null)
        messages="$yesterday_msgs"$'\n'"$messages"
    fi

    if [[ -z "$messages" ]]; then
        # Fall back to latest.json
        if [[ -f "$LATEST_FILE" ]]; then
            local from=$(jq -r '.from // "unknown"' "$LATEST_FILE")
            local text=$(jq -r '.text // ""' "$LATEST_FILE")
            local timestamp=$(jq -r '.timestamp // ""' "$LATEST_FILE")

            if [[ -n "$text" && "$text" != "null" ]]; then
                echo "## Telegram (last message)"
                echo ""
                echo "**@$from** ($timestamp):"
                echo "> $text"
            else
                echo "## Telegram: No recent messages"
            fi
        else
            echo "## Telegram: No recent messages"
        fi
        return
    fi

    # Format message history
    echo "## Telegram (recent conversation)"
    echo ""

    echo "$messages" | while IFS= read -r line; do
        [[ -z "$line" ]] && continue

        local from=$(echo "$line" | jq -r '.from.username // .from.first_name // .from // "unknown"' 2>/dev/null)
        local text=$(echo "$line" | jq -r '.text // ""' 2>/dev/null)
        local date_ts=$(echo "$line" | jq -r '.date // 0' 2>/dev/null)
        local outgoing=$(echo "$line" | jq -r '.outgoing // false' 2>/dev/null)

        [[ -z "$text" || "$text" == "null" ]] && continue

        # Format timestamp
        local timestamp=""
        if [[ "$date_ts" != "0" && "$date_ts" != "null" ]]; then
            timestamp=$(date -r "$date_ts" +%H:%M 2>/dev/null || date -d "@$date_ts" +%H:%M 2>/dev/null || echo "")
        fi

        # Format direction indicator
        local direction=""
        [[ "$outgoing" == "true" ]] && direction="→" || direction="←"

        echo "$direction **@$from** ($timestamp): $text"
    done

    echo ""
    echo "_Reply via: \`metasphere-telegram send \"message\"\`_"
}

# Send proactive message from agent
send_message() {
    local text="$1"
    local agent="${METASPHERE_AGENT_ID:-@orchestrator}"
    # Strip @ for display to avoid Telegram creating clickable mention
    local agent_display="${agent#@}"

    [[ -z "$TELEGRAM_BOT_TOKEN" ]] && {
        echo "Error: TELEGRAM_BOT_TOKEN not set"
        return 1
    }

    local chat_id
    [[ -f "$CHAT_ID_FILE" ]] && chat_id=$(cat "$CHAT_ID_FILE")

    [[ -z "$chat_id" ]] && {
        echo "Error: No chat ID. User must message bot first."
        return 1
    }

    # Format with agent attribution (no @ to avoid clickable mention)
    local formatted_text="*[${agent_display}]*

$text"

    curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
        -d "chat_id=$chat_id" \
        -d "parse_mode=Markdown" \
        --data-urlencode "text=$formatted_text" > /dev/null

    echo "Sent to Telegram via $agent"

    # Also archive outgoing message
    local outgoing=$(jq -n \
        --arg from "$agent" \
        --arg text "$text" \
        --arg chat_id "$chat_id" \
        '{from: {username: $from}, text: $text, chat: {id: ($chat_id|tonumber)}, date: now, outgoing: true}')

    archive_message "$outgoing"
}

# Daemon mode
daemon_mode() {
    local interval="${1:-5}"

    echo "Starting Telegram stream daemon"
    echo "  Poll interval: ${interval}s"
    echo "  Archive: $STREAM_DIR"
    echo "  Latest: $LATEST_FILE"
    echo ""

    while true; do
        poll_once 2>/dev/null || true
        sleep "$interval"
    done
}

# Main dispatch
case "${1:-}" in
    daemon)
        daemon_mode "${2:-5}"
        ;;
    once|poll)
        poll_once
        ;;
    latest)
        get_latest
        ;;
    context)
        shift
        format_context "$@"
        ;;
    send)
        shift
        send_message "$*"
        ;;
    archive)
        echo "Archive location: $STREAM_DIR"
        ls -la "$STREAM_DIR" 2>/dev/null || echo "(empty)"
        ;;
    *)
        cat << 'EOF'
metasphere-telegram-stream - Telegram archival and CAM integration

Usage:
  metasphere-telegram-stream daemon [N]   Poll continuously (default 5s)
  metasphere-telegram-stream once         Single poll
  metasphere-telegram-stream latest       Show latest message (JSON)
  metasphere-telegram-stream context      Format latest for agent context
  metasphere-telegram-stream send "msg"   Send message as current agent
  metasphere-telegram-stream archive      Show archive location

Archives:
  ~/.metasphere/telegram/stream/YYYY-MM-DD.jsonl  Daily message archive
  ~/.metasphere/telegram/latest.json              Most recent message

Messages are automatically indexed into CAM for searchable history.
EOF
        exit 1
        ;;
esac
