#!/bin/bash
# metasphere-fts - Fast file-based search ranker (poor man's BM25)
# Replaces per-turn `cam context` in the context hook. `cam search` remains
# available for explicit, entity-enriched discovery by agents.
#
# Usage: metasphere-fts "query string" [top_n]
#
# Scoring: for each file, count distinct query tokens that match (case-
# insensitive), then weight by inverse log(file_length). Returns top N files
# with path, score, and a 3-line snippet around the best match.

set -euo pipefail

QUERY="${1:-}"
TOP_N="${2:-5}"

if [[ -z "$QUERY" ]]; then
    echo "No query provided."
    exit 0
fi

REPO_ROOT="${METASPHERE_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
METASPHERE_DIR="${METASPHERE_DIR:-$HOME/.metasphere}"

# Corpus: markdown files in relevant locations (configurable via METASPHERE_FTS_CORPUS)
CORPUS_DIRS=(
    "$REPO_ROOT/docs"
    "$REPO_ROOT/scripts"
    "$REPO_ROOT/.messages"
    "$REPO_ROOT/.tasks"
    "$REPO_ROOT/templates"
    "$METASPHERE_DIR/agents"
)
if [[ -n "${METASPHERE_FTS_CORPUS:-}" ]]; then
    # Space-separated override
    read -r -a CORPUS_DIRS <<< "$METASPHERE_FTS_CORPUS"
fi

# Extract tokens: lowercase, alphanum, >=3 chars, drop stopwords
STOPWORDS=" the and for with this that from your you are was were have has will not but all any can has had its into per via of to in on at is it a an as be by or if so we us "
tokens=()
for raw in $(echo "$QUERY" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' ' '); do
    [[ ${#raw} -lt 3 ]] && continue
    [[ "$STOPWORDS" == *" $raw "* ]] && continue
    # dedupe
    skip=0
    for t in "${tokens[@]:-}"; do [[ "$t" == "$raw" ]] && skip=1 && break; done
    [[ $skip -eq 0 ]] && tokens+=("$raw")
done

if [[ ${#tokens[@]} -eq 0 ]]; then
    echo "No searchable tokens in query."
    exit 0
fi

# Build existing dirs list
existing_dirs=()
for d in "${CORPUS_DIRS[@]}"; do
    [[ -d "$d" ]] && existing_dirs+=("$d")
done
[[ ${#existing_dirs[@]} -eq 0 ]] && { echo "No corpus directories found."; exit 0; }

# Build alternation regex for single rg pass
alt="$(IFS='|'; echo "${tokens[*]}")"

# Single rg pass: file:linenum:content, count distinct tokens per file.
# Use awk to aggregate: score = distinct_token_count / log(lines+10)
rg --no-messages -i -n --with-filename --type md -e "\b($alt)\b" \
    "${existing_dirs[@]}" 2>/dev/null \
  | awk -v tokens="$alt" -v topn="$TOP_N" '
BEGIN {
    n = split(tokens, tarr, "|")
    for (i=1;i<=n;i++) tidx[tarr[i]] = i
}
{
    # parse file:line:rest
    p1 = index($0, ":")
    file = substr($0, 1, p1-1)
    rest = substr($0, p1+1)
    p2 = index(rest, ":")
    line = substr(rest, 1, p2-1) + 0
    content = tolower(substr(rest, p2+1))

    # find which tokens appear on this line
    for (tk in tidx) {
        if (index(content, tk) > 0) {
            key = file SUBSEP tk
            if (!(key in seen)) {
                seen[key] = 1
                distinct[file]++
                # remember first matching line for best snippet
                if (!(file in bestline)) bestline[file] = line
            }
        }
    }
    hits[file]++
}
END {
    for (f in distinct) {
        # length penalty: use hit count as proxy, weight inverse
        h = hits[f] + 0
        score = distinct[f] * 10 + (h / (h + 5))
        printf "%.4f\t%d\t%s\n", score, bestline[f], f
    }
}' | sort -rn | head -n "$TOP_N" | while IFS=$'\t' read -r score bline file; do
    [[ -z "$file" ]] && continue
    rel="${file#$REPO_ROOT/}"
    rel="${rel#$HOME/}"
    echo "### $rel  (score: $score)"
    start=$(( bline > 1 ? bline - 1 : 1 ))
    end=$(( bline + 1 ))
    awk -v s="$start" -v e="$end" 'NR>=s && NR<=e {print "    " $0} NR>e {exit}' "$file" 2>/dev/null
    echo ""
done
