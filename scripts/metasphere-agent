#!/bin/bash
# metasphere-agent - Agent lifecycle management
#
# Manages the full agent lifecycle:
#   - Spawning with scope/task/personality
#   - Status tracking (spawned → active → blocked → complete → sunset)
#   - Sunset with learning documentation
#   - Personality persistence (SOUL.md)
#
# Directory structure per agent:
#   ~/.metasphere/agents/@name/
#     ├── SOUL.md           # Personality/values (persists across incarnations)
#     ├── status            # Current status line
#     ├── scope             # Working directory (project tree level)
#     ├── task              # Current task description
#     ├── parent            # Parent agent ID
#     ├── children          # Child agent IDs (one per line)
#     ├── session.log       # Current session transcript
#     ├── learnings/        # Documented learnings (preserved)
#     │   └── YYYY-MM-DD-*.md
#     └── history/          # Past incarnations
#         └── YYYY-MM-DD-*.json
#
# Usage:
#   metasphere agent spawn @name --scope /path --task "description" [--parent @parent]
#   metasphere agent status [@name]
#   metasphere agent update @name --status "working: on feature X"
#   metasphere agent sunset @name [--reason "completed task"]
#   metasphere agent resume @name
#   metasphere agent list [--tree]

set -e

METASPHERE_DIR="${METASPHERE_DIR:-$HOME/.metasphere}"
AGENTS_DIR="$METASPHERE_DIR/agents"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

mkdir -p "$AGENTS_DIR"

# Colors
if [[ -t 1 ]]; then
    RED=$'\033[0;31m'
    YELLOW=$'\033[1;33m'
    GREEN=$'\033[0;32m'
    CYAN=$'\033[0;36m'
    DIM=$'\033[2m'
    BOLD=$'\033[1m'
    NC=$'\033[0m'
else
    RED='' YELLOW='' GREEN='' CYAN='' DIM='' BOLD='' NC=''
fi

# =============================================================================
# Agent Status States
# =============================================================================
# spawned     - Just created, not yet active
# active      - Currently running/responsive
# working:X   - Actively working on X
# blocked:X   - Waiting for X (dependency, input, etc.)
# idle        - Not working but available
# complete    - Task finished successfully
# failed:X    - Task failed with reason X
# sunset      - Gracefully shutting down

# =============================================================================
# Spawn a new agent
# =============================================================================

cmd_spawn() {
    local name=""
    local scope="$PWD"
    local task=""
    local parent=""
    local soul_template=""
    local sandbox="none"
    local interactive=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            @*)
                name="$1"
                ;;
            --scope|-s)
                scope="$2"
                shift
                ;;
            --task|-t)
                task="$2"
                shift
                ;;
            --parent|-p)
                parent="$2"
                shift
                ;;
            --soul)
                soul_template="$2"
                shift
                ;;
            --sandbox)
                sandbox="$2"
                shift
                ;;
            --interactive|-i)
                interactive=true
                ;;
            *)
                [[ -z "$task" ]] && task="$1"
                ;;
        esac
        shift
    done

    [[ -z "$name" ]] && {
        echo "Usage: metasphere agent spawn @name --scope /path --task \"description\""
        exit 1
    }

    local agent_dir="$AGENTS_DIR/$name"
    mkdir -p "$agent_dir/learnings" "$agent_dir/history"

    # Initialize or preserve SOUL.md
    if [[ ! -f "$agent_dir/SOUL.md" ]]; then
        if [[ -n "$soul_template" && -f "$soul_template" ]]; then
            cp "$soul_template" "$agent_dir/SOUL.md"
        else
            cat > "$agent_dir/SOUL.md" << EOF
# $name Soul

## Identity
I am $name, a specialized agent in the Metasphere ecosystem.

## Core Values
- Focus on assigned task
- Communicate clearly with team
- Document learnings for future
- Know when to escalate

## Scope
Working within: $scope

## Notes
(Add personality traits, preferences, learned behaviors here)
EOF
        fi
    fi

    # Set current state
    echo "$scope" > "$agent_dir/scope"
    echo "spawned" > "$agent_dir/status"
    echo "$sandbox" > "$agent_dir/sandbox"
    [[ -n "$task" ]] && echo "$task" > "$agent_dir/task"
    [[ -n "$parent" ]] && echo "$parent" > "$agent_dir/parent"
    date -u +%Y-%m-%dT%H:%M:%SZ > "$agent_dir/spawned_at"

    # Inherit sandbox from parent if not specified
    if [[ "$sandbox" == "none" && -n "$parent" && -f "$AGENTS_DIR/$parent/sandbox" ]]; then
        local parent_sandbox=$(cat "$AGENTS_DIR/$parent/sandbox")
        # Child can only be same or more restrictive
        echo "$parent_sandbox" > "$agent_dir/sandbox"
        sandbox="$parent_sandbox"
    fi

    # Register with parent
    if [[ -n "$parent" && -d "$AGENTS_DIR/$parent" ]]; then
        echo "$name" >> "$AGENTS_DIR/$parent/children"
    fi

    # Log spawn event
    echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] SPAWN scope=$scope task=\"$task\" parent=$parent" >> "$agent_dir/session.log"
    "$SCRIPT_DIR/metasphere-events" log agent.spawn "Spawned $name: $task" --agent "${parent:-@system}" --meta sandbox="$sandbox" 2>/dev/null || true

    echo -e "${GREEN}✓${NC} Spawned $name"
    echo "  Scope: $scope"
    echo "  Sandbox: $sandbox"
    [[ -n "$task" ]] && echo "  Task: $task"
    [[ -n "$parent" ]] && echo "  Parent: $parent"
    echo "  Dir: $agent_dir"

    # Start interactive session if requested
    if $interactive; then
        echo
        "$SCRIPT_DIR/metasphere-session" start "$name"
    fi
}

# =============================================================================
# Update agent status
# =============================================================================

cmd_update() {
    local name=""
    local new_status=""
    local note=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            @*)
                name="$1"
                ;;
            --status|-s)
                new_status="$2"
                shift
                ;;
            --note|-n)
                note="$2"
                shift
                ;;
            *)
                [[ -z "$new_status" ]] && new_status="$1"
                ;;
        esac
        shift
    done

    [[ -z "$name" ]] && {
        echo "Usage: metasphere agent update @name --status \"working: on X\""
        exit 1
    }

    local agent_dir="$AGENTS_DIR/$name"
    [[ ! -d "$agent_dir" ]] && {
        echo "Agent not found: $name"
        exit 1
    }

    local old_status=$(cat "$agent_dir/status" 2>/dev/null || echo "unknown")
    echo "$new_status" > "$agent_dir/status"
    date -u +%Y-%m-%dT%H:%M:%SZ > "$agent_dir/updated_at"

    # Log status change
    echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] STATUS $old_status → $new_status" >> "$agent_dir/session.log"
    [[ -n "$note" ]] && echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] NOTE $note" >> "$agent_dir/session.log"
    "$SCRIPT_DIR/metasphere-events" log agent.status "$name: $new_status" --agent "$name" 2>/dev/null || true

    echo -e "${GREEN}✓${NC} $name: $new_status"
}

# =============================================================================
# Sunset an agent (graceful shutdown with documentation)
# =============================================================================

cmd_sunset() {
    local name=""
    local reason="task complete"
    local skip_docs=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            @*)
                name="$1"
                ;;
            --reason|-r)
                reason="$2"
                shift
                ;;
            --skip-docs)
                skip_docs=true
                ;;
            *)
                [[ -z "$reason" ]] && reason="$1"
                ;;
        esac
        shift
    done

    [[ -z "$name" ]] && {
        echo "Usage: metasphere agent sunset @name [--reason \"completed task\"]"
        exit 1
    }

    local agent_dir="$AGENTS_DIR/$name"
    [[ ! -d "$agent_dir" ]] && {
        echo "Agent not found: $name"
        exit 1
    }

    echo -e "${CYAN}Sunsetting $name...${NC}"

    # Update status
    echo "sunset: $reason" > "$agent_dir/status"
    echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] SUNSET reason=\"$reason\"" >> "$agent_dir/session.log"
    "$SCRIPT_DIR/metasphere-events" log agent.sunset "$name sunset: $reason" --agent "$name" 2>/dev/null || true

    # Generate learnings document if not skipping
    if ! $skip_docs; then
        local learnings_file="$agent_dir/learnings/$(date +%Y-%m-%d)-sunset.md"
        local task=$(cat "$agent_dir/task" 2>/dev/null || echo "unspecified")
        local scope=$(cat "$agent_dir/scope" 2>/dev/null || echo "unknown")
        local spawned=$(cat "$agent_dir/spawned_at" 2>/dev/null || echo "unknown")

        cat > "$learnings_file" << EOF
# $name Sunset Report
Date: $(date -u +%Y-%m-%dT%H:%M:%SZ)
Reason: $reason

## Task
$task

## Scope
$scope

## Duration
Spawned: $spawned
Sunset: $(date -u +%Y-%m-%dT%H:%M:%SZ)

## Key Learnings
<!-- Document what was learned during this incarnation -->

1.

## Challenges Encountered
<!-- What blocked progress or was difficult -->

1.

## Recommendations
<!-- Advice for future agents working on similar tasks -->

1.

## Handoff Notes
<!-- Anything the next agent should know -->

EOF

        echo -e "  ${YELLOW}→${NC} Created learnings document: $learnings_file"
        echo "  Edit this file to document learnings before final shutdown."
    fi

    # Archive session to history
    local history_file="$agent_dir/history/$(date +%Y-%m-%d)-session.json"
    jq -n \
        --arg name "$name" \
        --arg task "$(cat "$agent_dir/task" 2>/dev/null)" \
        --arg scope "$(cat "$agent_dir/scope" 2>/dev/null)" \
        --arg spawned "$(cat "$agent_dir/spawned_at" 2>/dev/null)" \
        --arg sunset "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        --arg reason "$reason" \
        '{name: $name, task: $task, scope: $scope, spawned: $spawned, sunset: $sunset, reason: $reason}' \
        > "$history_file"

    # Notify parent if exists
    local parent=$(cat "$agent_dir/parent" 2>/dev/null || echo "")
    if [[ -n "$parent" ]]; then
        "$SCRIPT_DIR/messages" send "$parent" "!sunset" "$name has completed: $reason" 2>/dev/null || true
    fi

    # Check for orphaned children
    if [[ -f "$agent_dir/children" ]]; then
        local children=$(cat "$agent_dir/children")
        if [[ -n "$children" ]]; then
            echo -e "  ${YELLOW}!${NC} Agent has children that may need attention:"
            echo "$children" | while read -r child; do
                echo "    - $child"
            done
        fi
    fi

    echo -e "${GREEN}✓${NC} $name sunset complete"
}

# =============================================================================
# Resume a sunset/idle agent
# =============================================================================

cmd_resume() {
    local name="$1"
    local new_task="${2:-}"

    [[ -z "$name" || "$name" != @* ]] && {
        echo "Usage: metasphere agent resume @name [\"new task\"]"
        exit 1
    }

    local agent_dir="$AGENTS_DIR/$name"
    [[ ! -d "$agent_dir" ]] && {
        echo "Agent not found: $name"
        exit 1
    }

    echo "active" > "$agent_dir/status"
    [[ -n "$new_task" ]] && echo "$new_task" > "$agent_dir/task"
    date -u +%Y-%m-%dT%H:%M:%SZ > "$agent_dir/updated_at"

    echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] RESUME" >> "$agent_dir/session.log"

    echo -e "${GREEN}✓${NC} Resumed $name"
}

# =============================================================================
# Show agent status
# =============================================================================

cmd_status() {
    local name="${1:-}"

    if [[ -n "$name" && "$name" == @* ]]; then
        # Single agent status
        local agent_dir="$AGENTS_DIR/$name"
        [[ ! -d "$agent_dir" ]] && {
            echo "Agent not found: $name"
            exit 1
        }

        echo -e "${BOLD}$name${NC}"
        echo
        echo "Status:  $(cat "$agent_dir/status" 2>/dev/null || echo "unknown")"
        echo "Scope:   $(cat "$agent_dir/scope" 2>/dev/null || echo "unset")"
        echo "Task:    $(cat "$agent_dir/task" 2>/dev/null || echo "none")"
        [[ -f "$agent_dir/parent" ]] && echo "Parent:  $(cat "$agent_dir/parent")"
        [[ -f "$agent_dir/spawned_at" ]] && echo "Spawned: $(cat "$agent_dir/spawned_at")"
        [[ -f "$agent_dir/updated_at" ]] && echo "Updated: $(cat "$agent_dir/updated_at")"

        if [[ -f "$agent_dir/children" && -s "$agent_dir/children" ]]; then
            echo "Children:"
            cat "$agent_dir/children" | while read -r child; do
                local child_status=$(cat "$AGENTS_DIR/$child/status" 2>/dev/null || echo "?")
                echo "  - $child ($child_status)"
            done
        fi

        if [[ -d "$agent_dir/learnings" ]]; then
            local learning_count=$(ls "$agent_dir/learnings"/*.md 2>/dev/null | wc -l | tr -d ' ')
            [[ $learning_count -gt 0 ]] && echo "Learnings: $learning_count documents"
        fi
    else
        # All agents overview
        echo -e "${BOLD}Agent Status${NC}"
        echo

        for agent_dir in "$AGENTS_DIR"/@*/; do
            [[ -d "$agent_dir" ]] || continue

            local agent=$(basename "$agent_dir")
            local status=$(cat "$agent_dir/status" 2>/dev/null || echo "unknown")
            local scope=$(cat "$agent_dir/scope" 2>/dev/null | sed "s|$HOME|~|")
            local task=$(cat "$agent_dir/task" 2>/dev/null | head -c 50)

            # Status icon
            local icon="○"
            case "$status" in
                active*|working:*) icon="${GREEN}●${NC}" ;;
                spawned) icon="${YELLOW}◐${NC}" ;;
                blocked:*) icon="${RED}◐${NC}" ;;
                idle) icon="${DIM}○${NC}" ;;
                complete*) icon="${GREEN}✓${NC}" ;;
                sunset*) icon="${DIM}◇${NC}" ;;
                failed:*) icon="${RED}✗${NC}" ;;
            esac

            echo -e "$icon ${BOLD}$agent${NC}"
            echo -e "  ${DIM}$status${NC}"
            [[ -n "$scope" ]] && echo -e "  ${DIM}scope: $scope${NC}"
            [[ -n "$task" ]] && echo -e "  ${DIM}task: $task${NC}"
            echo
        done
    fi
}

# =============================================================================
# List agents as tree (showing parent-child relationships)
# =============================================================================

cmd_tree() {
    echo -e "${BOLD}Agent Hierarchy${NC}"
    echo

    # Find root agents (no parent)
    local printed=()

    print_agent() {
        local name="$1"
        local indent="$2"

        local agent_dir="$AGENTS_DIR/$name"
        [[ ! -d "$agent_dir" ]] && return

        local status=$(cat "$agent_dir/status" 2>/dev/null || echo "?")
        local scope=$(cat "$agent_dir/scope" 2>/dev/null | sed "s|$HOME|~|" | sed 's|.*/||')

        # Status icon
        local icon="○"
        case "$status" in
            active*|working:*) icon="${GREEN}●${NC}" ;;
            spawned) icon="${YELLOW}◐${NC}" ;;
            blocked:*) icon="${RED}◐${NC}" ;;
            complete*) icon="${GREEN}✓${NC}" ;;
            sunset*) icon="${DIM}◇${NC}" ;;
        esac

        echo -e "${indent}$icon $name ${DIM}[$scope]${NC}"

        # Print children
        if [[ -f "$agent_dir/children" ]]; then
            cat "$agent_dir/children" | while read -r child; do
                [[ -n "$child" ]] && print_agent "$child" "  $indent"
            done
        fi
    }

    # Find and print root agents
    for agent_dir in "$AGENTS_DIR"/@*/; do
        [[ -d "$agent_dir" ]] || continue
        local agent=$(basename "$agent_dir")

        # Skip if has parent
        [[ -f "$agent_dir/parent" ]] && continue

        print_agent "$agent" ""
    done
}

# =============================================================================
# Clean up stuck/orphaned agents
# =============================================================================

cmd_cleanup() {
    echo -e "${BOLD}Cleaning up agents...${NC}"
    echo

    local cleaned=0

    for agent_dir in "$AGENTS_DIR"/@*/; do
        [[ -d "$agent_dir" ]] || continue

        local agent=$(basename "$agent_dir")
        local status=$(cat "$agent_dir/status" 2>/dev/null || echo "unknown")
        local updated=$(cat "$agent_dir/updated_at" 2>/dev/null || cat "$agent_dir/spawned_at" 2>/dev/null || echo "")

        # Check for stale spawned agents (spawned > 1 hour ago, never updated)
        if [[ "$status" == "spawned" && -n "$updated" ]]; then
            local updated_ts=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$updated" +%s 2>/dev/null || date -d "$updated" +%s 2>/dev/null || echo 0)
            local now_ts=$(date +%s)
            local age=$((now_ts - updated_ts))

            if [[ $age -gt 3600 ]]; then
                echo -e "  ${YELLOW}!${NC} $agent: spawned ${age}s ago, never activated"
                echo "    Consider: metasphere agent sunset $agent --reason \"stale spawn\""
                ((cleaned++))
            fi
        fi

        # Check for orphaned children
        if [[ -f "$agent_dir/parent" ]]; then
            local parent=$(cat "$agent_dir/parent")
            if [[ ! -d "$AGENTS_DIR/$parent" ]]; then
                echo -e "  ${RED}!${NC} $agent: parent $parent no longer exists"
                ((cleaned++))
            fi
        fi
    done

    [[ $cleaned -eq 0 ]] && echo -e "  ${GREEN}✓${NC} No issues found"
}

# =============================================================================
# Subtree view - see all descendants
# =============================================================================

cmd_subtree() {
    local name="${1:-@orchestrator}"
    [[ "$name" != @* ]] && name="@$name"

    local agent_dir="$AGENTS_DIR/$name"
    [[ ! -d "$agent_dir" ]] && {
        echo "Agent not found: $name"
        exit 1
    }

    echo -e "${BOLD}Subtree: $name${NC}"
    echo

    # Recursive function to print subtree
    print_subtree() {
        local agent="$1"
        local indent="$2"
        local agent_dir="$AGENTS_DIR/$agent"

        local status=$(cat "$agent_dir/status" 2>/dev/null || echo "?")
        local task=$(cat "$agent_dir/task" 2>/dev/null | head -c 40)

        # Status icon
        local icon="○"
        case "$status" in
            active*|working:*) icon="${GREEN}●${NC}" ;;
            spawned) icon="${YELLOW}◐${NC}" ;;
            blocked:*) icon="${RED}◐${NC}" ;;
            complete*|sunset*) icon="${DIM}✓${NC}" ;;
        esac

        echo -e "${indent}$icon $agent"
        echo -e "${indent}  ${DIM}$status${NC}"
        [[ -n "$task" ]] && echo -e "${indent}  ${DIM}task: $task${NC}"

        # Recurse into children
        if [[ -f "$agent_dir/children" ]]; then
            cat "$agent_dir/children" | while read -r child; do
                [[ -n "$child" && -d "$AGENTS_DIR/$child" ]] && print_subtree "$child" "  $indent"
            done
        fi
    }

    print_subtree "$name" ""
}

# =============================================================================
# Report - bubble up status to parent
# =============================================================================

cmd_report() {
    local name="${1:-}"
    local message="${2:-}"

    [[ -z "$name" || "$name" != @* ]] && {
        echo "Usage: metasphere agent report @name \"status message\""
        exit 1
    }

    local agent_dir="$AGENTS_DIR/$name"
    [[ ! -d "$agent_dir" ]] && {
        echo "Agent not found: $name"
        exit 1
    }

    local parent=$(cat "$agent_dir/parent" 2>/dev/null || echo "")
    local timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    # Log to agent's session log
    echo "[$timestamp] REPORT $message" >> "$agent_dir/session.log"

    # Create report file
    local report_file="$agent_dir/reports/$(date +%Y-%m-%d-%H%M%S).md"
    mkdir -p "$agent_dir/reports"

    cat > "$report_file" << EOF
# Report from $name
Time: $timestamp

## Status
$(cat "$agent_dir/status" 2>/dev/null || echo "unknown")

## Message
$message

## Current Task
$(cat "$agent_dir/task" 2>/dev/null || echo "none")
EOF

    # Bubble up to parent if exists
    if [[ -n "$parent" && -d "$AGENTS_DIR/$parent" ]]; then
        # Send message to parent
        "$SCRIPT_DIR/messages" send "$parent" "!report" "[$name] $message" 2>/dev/null || true

        # Copy report to parent's inbox
        mkdir -p "$AGENTS_DIR/$parent/child_reports"
        cp "$report_file" "$AGENTS_DIR/$parent/child_reports/${name#@}-$(date +%Y%m%d%H%M%S).md"
    fi

    # Log event
    "$SCRIPT_DIR/metasphere-events" log agent.report "$name: $message" --agent "$name" 2>/dev/null || true

    echo "Report sent: $message"
    [[ -n "$parent" ]] && echo "  Bubbled up to: $parent"
}

# =============================================================================
# View - show what agent can see (downward visibility)
# =============================================================================

cmd_view() {
    local name="${1:-@orchestrator}"
    [[ "$name" != @* ]] && name="@$name"

    local agent_dir="$AGENTS_DIR/$name"
    [[ ! -d "$agent_dir" ]] && {
        echo "Agent not found: $name"
        exit 1
    }

    echo -e "${BOLD}$name View${NC}"
    echo

    # Own status
    echo -e "${BOLD}Self${NC}"
    echo "  Status: $(cat "$agent_dir/status" 2>/dev/null || echo "?")"
    echo "  Task: $(cat "$agent_dir/task" 2>/dev/null | head -c 60)"
    echo

    # Child reports (what's bubbled up)
    if [[ -d "$agent_dir/child_reports" ]]; then
        local report_count=$(ls "$agent_dir/child_reports"/*.md 2>/dev/null | wc -l | tr -d ' ')
        if [[ $report_count -gt 0 ]]; then
            echo -e "${BOLD}Child Reports${NC} ($report_count)"
            ls -t "$agent_dir/child_reports"/*.md 2>/dev/null | head -5 | while read -r f; do
                local child=$(basename "$f" | cut -d- -f1)
                local summary=$(grep "^## Message" -A1 "$f" 2>/dev/null | tail -1 | head -c 50)
                echo "  @$child: $summary"
            done
            echo
        fi
    fi

    # Subtree summary
    echo -e "${BOLD}Subtree${NC}"
    local total=0 active=0 blocked=0

    collect_subtree_stats() {
        local a="$1"
        local ad="$AGENTS_DIR/$a"
        ((total++))

        local s=$(cat "$ad/status" 2>/dev/null || echo "")
        case "$s" in
            active*|working:*) ((active++)) ;;
            blocked:*) ((blocked++)) ;;
        esac

        if [[ -f "$ad/children" ]]; then
            cat "$ad/children" | while read -r c; do
                [[ -n "$c" && -d "$AGENTS_DIR/$c" ]] && collect_subtree_stats "$c"
            done
        fi
    }

    # Can't easily return from subshell, so use file
    (collect_subtree_stats "$name"; echo "$total $active $blocked") | tail -1 | read t a b
    echo "  Total: ${t:-1} agents, ${a:-0} active, ${b:-0} blocked"

    # Messages in scope
    echo
    echo -e "${BOLD}Pending Messages${NC}"
    "$SCRIPT_DIR/messages" 2>/dev/null | head -5 || echo "  (none)"
}

# =============================================================================
# Main dispatch
# =============================================================================

case "${1:-}" in
    spawn|new)
        shift
        cmd_spawn "$@"
        ;;
    update|set)
        shift
        cmd_update "$@"
        ;;
    sunset|retire|stop)
        shift
        cmd_sunset "$@"
        ;;
    resume|start)
        shift
        cmd_resume "$@"
        ;;
    status|show)
        shift
        cmd_status "$@"
        ;;
    tree|hierarchy)
        cmd_tree
        ;;
    list|ls)
        cmd_status
        ;;
    cleanup|clean)
        cmd_cleanup
        ;;
    *)
        cat << 'EOF'
metasphere-agent - Agent lifecycle management

Usage:
  metasphere agent spawn @name [options]    Create new agent
  metasphere agent status [@name]           Show status
  metasphere agent update @name --status X  Update status
  metasphere agent sunset @name             Graceful shutdown
  metasphere agent resume @name             Reactivate agent
  metasphere agent tree                     Show hierarchy
  metasphere agent cleanup                  Find stale agents

Spawn options:
  --scope, -s PATH     Working directory (project tree level)
  --task, -t "desc"    Task description
  --parent, -p @name   Parent agent
  --soul FILE          SOUL.md template

Status states:
  spawned      Just created
  active       Running
  working:X    Working on X
  blocked:X    Waiting for X
  idle         Available
  complete     Task done
  sunset       Shutting down

Agent directory: ~/.metasphere/agents/@name/
  SOUL.md       Personality (persists)
  learnings/    Documented learnings
  history/      Past sessions
EOF
        exit 1
        ;;
esac
