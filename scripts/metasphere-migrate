#!/bin/bash
# metasphere-migrate - Migrate from OpenClaw to Metasphere
#
# Handles backwards compatibility with OpenClaw:
#   - Extracts Telegram token from openclaw.json
#   - Migrates SOUL.md and agent profiles
#   - Imports memory files
#   - Triggers CAM to parse existing sessions
#   - Optionally disables OpenClaw gateway
#
# Usage:
#   metasphere-migrate detect              Check for OpenClaw installation
#   metasphere-migrate run [--disable]     Run full migration
#   metasphere-migrate telegram            Extract Telegram token only
#   metasphere-migrate sessions            Parse sessions with CAM

set -e

METASPHERE_DIR="${METASPHERE_DIR:-$HOME/.metasphere}"
OPENCLAW_DIR="${OPENCLAW_DIR:-$HOME/.openclaw}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Colors
if [[ -t 1 ]]; then
    GREEN=$'\033[0;32m'
    YELLOW=$'\033[1;33m'
    RED=$'\033[0;31m'
    CYAN=$'\033[0;36m'
    DIM=$'\033[2m'
    NC=$'\033[0m'
else
    GREEN='' YELLOW='' RED='' CYAN='' DIM='' NC=''
fi

ok() { echo -e "${GREEN}[ok]${NC} $*"; }
info() { echo -e "${CYAN}[..]${NC} $*"; }
warn() { echo -e "${YELLOW}[!!]${NC} $*"; }
err() { echo -e "${RED}[error]${NC} $*"; }

# =============================================================================
# Detection
# =============================================================================

detect_openclaw() {
    local found=false

    echo "OpenClaw Detection"
    echo "=================="
    echo

    # Check ~/.openclaw directory
    if [[ -d "$OPENCLAW_DIR" ]]; then
        ok "Found OpenClaw directory: $OPENCLAW_DIR"
        found=true

        # Check for config file
        if [[ -f "$OPENCLAW_DIR/openclaw.json" ]]; then
            ok "  Config: openclaw.json"

            # Check for tokens
            if jq -e '.telegram' "$OPENCLAW_DIR/openclaw.json" &>/dev/null; then
                ok "  Telegram config found"
            fi
            if jq -e '.github' "$OPENCLAW_DIR/openclaw.json" &>/dev/null || \
               jq -e '.GITHUB_TOKEN' "$OPENCLAW_DIR/openclaw.json" &>/dev/null; then
                ok "  GitHub token found"
            fi
        fi

        # Check for SOUL.md
        if [[ -f "$OPENCLAW_DIR/SOUL.md" ]]; then
            ok "  SOUL.md found"
        fi

        # Check for memory files
        local memory_count=$(find "$OPENCLAW_DIR" -name "*.memory" -o -name "memory.json" 2>/dev/null | wc -l | tr -d ' ')
        if [[ $memory_count -gt 0 ]]; then
            ok "  Memory files: $memory_count"
        fi

        # Check for skills
        if [[ -d "$OPENCLAW_DIR/skills" ]]; then
            local skill_count=$(find "$OPENCLAW_DIR/skills" -name "SKILL.md" 2>/dev/null | wc -l | tr -d ' ')
            ok "  Skills: $skill_count"
        fi
    else
        info "No OpenClaw directory found at $OPENCLAW_DIR"
    fi

    # Check for running gateway
    echo
    echo "Gateway Status"
    echo "--------------"

    if [[ "$(uname)" == "Darwin" ]]; then
        if launchctl list 2>/dev/null | grep -q "openclaw"; then
            warn "OpenClaw gateway running (launchd)"
        else
            info "No OpenClaw launchd service"
        fi
    else
        if systemctl --user is-active openclaw-gateway &>/dev/null; then
            warn "OpenClaw gateway running (systemd)"
        else
            info "No OpenClaw systemd service"
        fi
    fi

    # Check CAM sessions
    echo
    echo "CAM Sessions"
    echo "------------"

    if [[ -d "$HOME/.cam/sessions" ]]; then
        local session_count=$(find "$HOME/.cam/sessions" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
        ok "Found $session_count CAM session segments"
    else
        info "No CAM sessions found"
    fi

    # Check Claude Code sessions
    if [[ -d "$HOME/.claude/projects" ]]; then
        local claude_session_count=$(find "$HOME/.claude/projects" -name "*.jsonl" 2>/dev/null | wc -l | tr -d ' ')
        ok "Found $claude_session_count Claude Code sessions"
    fi

    echo
    if $found; then
        echo "Run: metasphere-migrate run"
        echo "  to migrate OpenClaw configuration to Metasphere"
    fi
}

# =============================================================================
# Token extraction
# =============================================================================

extract_telegram_token() {
    local config="$OPENCLAW_DIR/openclaw.json"

    if [[ ! -f "$config" ]]; then
        warn "No openclaw.json found"
        return 1
    fi

    # Try different possible locations for Telegram token
    local token=""

    # Canonical openclaw location: channels.telegram.botToken
    token=$(jq -r '.channels.telegram.botToken // empty' "$config" 2>/dev/null)

    # Legacy/alternate locations
    [[ -z "$token" ]] && token=$(jq -r '.telegram.botToken // empty' "$config" 2>/dev/null)
    [[ -z "$token" ]] && token=$(jq -r '.TELEGRAM_BOT_TOKEN // empty' "$config" 2>/dev/null)
    [[ -z "$token" ]] && token=$(jq -r '.telegram_bot_token // empty' "$config" 2>/dev/null)
    [[ -z "$token" ]] && token=$(jq -r '.env.TELEGRAM_BOT_TOKEN // empty' "$config" 2>/dev/null)

    # tokenFile pointer (must be a regular file, not a symlink)
    if [[ -z "$token" ]]; then
        local tokenfile=$(jq -r '.channels.telegram.tokenFile // empty' "$config" 2>/dev/null)
        if [[ -n "$tokenfile" && -f "$tokenfile" && ! -L "$tokenfile" ]]; then
            token=$(cat "$tokenfile" 2>/dev/null | tr -d '[:space:]')
        fi
    fi

    if [[ -n "$token" && "$token" != "null" ]]; then
        echo "$token"
        return 0
    fi

    return 1
}

extract_github_token() {
    local config="$OPENCLAW_DIR/openclaw.json"

    if [[ ! -f "$config" ]]; then
        return 1
    fi

    local token=""
    token=$(jq -r '.GITHUB_TOKEN // .github.token // .env.GITHUB_TOKEN // empty' "$config" 2>/dev/null)

    if [[ -n "$token" && "$token" != "null" ]]; then
        echo "$token"
        return 0
    fi

    return 1
}

migrate_telegram() {
    info "Extracting Telegram configuration..."

    local token=$(extract_telegram_token)

    if [[ -n "$token" ]]; then
        mkdir -p "$METASPHERE_DIR/config"
        echo "TELEGRAM_BOT_TOKEN=$token" > "$METASPHERE_DIR/config/telegram.env"
        chmod 600 "$METASPHERE_DIR/config/telegram.env"

        # Verify token
        local bot_info=$(curl -s "https://api.telegram.org/bot$token/getMe" 2>/dev/null | jq -r '.result.username // empty')
        if [[ -n "$bot_info" ]]; then
            ok "Migrated Telegram token (bot: @$bot_info)"
        else
            warn "Migrated token but verification failed"
        fi
        return 0
    else
        warn "No Telegram token found in OpenClaw config"
        return 1
    fi
}

# =============================================================================
# SOUL.md migration
# =============================================================================

migrate_soul() {
    info "Migrating openclaw workspace files into native metasphere identity..."

    local agent_dir="$METASPHERE_DIR/agents/@orchestrator"
    mkdir -p "$agent_dir"

    # Canonical openclaw location: ~/.openclaw/workspace/<file>.md
    # Older layouts may have files at ~/.openclaw/<file>.md
    local workspace_dir=""
    if [[ -d "$OPENCLAW_DIR/workspace" ]]; then
        workspace_dir="$OPENCLAW_DIR/workspace"
    fi

    # Canonical openclaw workspace files per docs.openclaw.ai/concepts/agent-workspace.
    # We COPY (not symlink, not live-pointer) so metasphere becomes authoritative
    # after migration. ~/.openclaw stays intact as backup. Future edits should
    # happen in ~/.metasphere/agents/@orchestrator/.
    local workspace_files=(SOUL.md IDENTITY.md USER.md TOOLS.md AGENTS.md HEARTBEAT.md MEMORY.md BOOT.md BOOTSTRAP.md)
    local copied=0

    if [[ -n "$workspace_dir" ]]; then
        for f in "${workspace_files[@]}"; do
            local src="$workspace_dir/$f"
            local dst="$agent_dir/$f"
            if [[ -f "$src" && ! -f "$dst" ]]; then
                cp "$src" "$dst"
                copied=$((copied + 1))
            elif [[ -f "$src" && -f "$dst" ]]; then
                # Already exists — don't clobber. Show that it was preserved.
                :
            fi
        done
        ok "Copied $copied workspace files from $workspace_dir to $agent_dir"

        # Drop the legacy openclaw_workspace pointer if present. The whole
        # point of the refactor is that metasphere no longer reads through
        # openclaw at runtime — the per-host install owns its files.
        if [[ -f "$METASPHERE_DIR/config/openclaw_workspace" ]]; then
            rm -f "$METASPHERE_DIR/config/openclaw_workspace"
            ok "Dropped openclaw_workspace pointer (migration is now copy-based)"
        fi
    elif [[ -f "$OPENCLAW_DIR/SOUL.md" ]]; then
        # Pre-workspace layout fallback
        if [[ ! -f "$agent_dir/SOUL.md" ]]; then
            cp "$OPENCLAW_DIR/SOUL.md" "$agent_dir/SOUL.md"
            ok "Migrated legacy SOUL.md to @orchestrator"
        fi
    fi

    # Per-agent identity files: ~/.openclaw/agents/<id>/agent (or SOUL.md)
    # → ~/.metasphere/agents/@<id>/. These are the cron/research agents
    # documented in jobs.json (main, night, research-gather, etc.)
    if [[ -d "$OPENCLAW_DIR/agents" ]]; then
        local agent_count=0
        for d in "$OPENCLAW_DIR"/agents/*/; do
            [[ -d "$d" ]] || continue
            local agent_name=$(basename "$d")
            local target_dir="$METASPHERE_DIR/agents/@$agent_name"
            mkdir -p "$target_dir"

            # Copy the openclaw "agent" descriptor file if present
            if [[ -f "$d/agent" && ! -f "$target_dir/agent" ]]; then
                cp "$d/agent" "$target_dir/agent"
                agent_count=$((agent_count + 1))
            fi
            # Copy SOUL.md if present (older layouts)
            if [[ -f "$d/SOUL.md" && ! -f "$target_dir/SOUL.md" ]]; then
                cp "$d/SOUL.md" "$target_dir/SOUL.md"
            fi
            # Copy profile dir if present (main agent has this)
            if [[ -d "$d/profile" && ! -d "$target_dir/profile" ]]; then
                cp -r "$d/profile" "$target_dir/profile"
            fi
        done
        [[ $agent_count -gt 0 ]] && ok "Migrated $agent_count openclaw agent identities to @-named metasphere agents"
    fi

    # Generate persona-index.md so the agent's CLAUDE.md (or per-turn hook)
    # can @-reference it and the agent can lazy-Read individual files on
    # demand. No content is inlined — just absolute paths the agent can
    # use with the Read tool.
    write_persona_index "$agent_dir"
}

write_persona_index() {
    local agent_dir="$1"
    local index="$agent_dir/persona-index.md"

    {
        echo "# Persona Index — $(basename "$agent_dir")"
        echo
        echo "_Generated by metasphere-migrate on $(date -u +%Y-%m-%dT%H:%M:%SZ)._"
        echo "_Read these files with the Read tool ON DEMAND, not all at once._"
        echo
        echo "## Identity (read first when introducing yourself)"
        for f in IDENTITY.md SOUL.md USER.md; do
            [[ -f "$agent_dir/$f" ]] && echo "- $agent_dir/$f"
        done
        echo
        echo "## Operating rules (read when you need to recall procedures)"
        for f in AGENTS.md TOOLS.md BOOTSTRAP.md BOOT.md; do
            [[ -f "$agent_dir/$f" ]] && echo "- $agent_dir/$f"
        done
        echo
        echo "## Memory (read when you need historical context)"
        for f in MEMORY.md HEARTBEAT.md LEARNINGS.md MISSION.md; do
            [[ -f "$agent_dir/$f" ]] && echo "- $agent_dir/$f"
        done
        # Workspace memory dir (daily logs) if present from openclaw migration
        if [[ -d "$OPENCLAW_DIR/workspace/memory" ]]; then
            local mem_count
            mem_count=$(find "$OPENCLAW_DIR/workspace/memory" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
            echo "- $OPENCLAW_DIR/workspace/memory/  (daily logs, $mem_count files; read latest with: ls -t | head)"
        fi
        echo
        echo "## How to use this"
        echo
        echo "When the user asks something that touches your identity, persona, or"
        echo "operating rules, Read the relevant file from the lists above. Do NOT"
        echo "Read everything at session start — that wastes context. The whole"
        echo "point of this index is lazy loading."
    } > "$index"

    ok "Wrote $index"
}

# =============================================================================
# Cron migration: ~/.openclaw/cron/jobs.json → ~/.metasphere/schedule/jobs.json
# =============================================================================

migrate_cron() {
    info "Migrating openclaw cron jobs to metasphere schedule..."

    local src="$OPENCLAW_DIR/cron/jobs.json"
    local schedule_dir="$METASPHERE_DIR/schedule"
    local dst="$schedule_dir/jobs.json"

    if [[ ! -f "$src" ]]; then
        info "No openclaw cron jobs.json found"
        return 0
    fi

    mkdir -p "$schedule_dir"

    # Initialize empty schedule if missing
    [[ -f "$dst" ]] || echo '[]' > "$dst"

    local total enabled disabled portable nonportable
    total=$(jq '.jobs | length' "$src" 2>/dev/null || echo 0)
    enabled=$(jq '[.jobs[] | select(.enabled == true)] | length' "$src" 2>/dev/null || echo 0)
    disabled=$((total - enabled))

    info "  Found $total openclaw jobs ($enabled enabled, $disabled disabled)"

    # Transform openclaw schema -> metasphere schedule schema. We preserve the
    # original openclaw id, the agentId, name, cron expression, tz, and the
    # full payload message + model. Disabled jobs are skipped entirely (we
    # log them but don't carry them over). Anything previously imported with
    # the same id gets replaced (idempotent re-run).
    portable=0
    nonportable=0

    # Build the new entries as a JSON array
    local new_entries
    new_entries=$(jq -c --arg now "$(date +%s)" '
        [
            .jobs[]
            | select(.enabled == true)
            | select(.schedule.kind == "cron")
            | select(.schedule.expr != null and .schedule.expr != "")
            | {
                id: ("openclaw-" + .id),
                source: "openclaw-migrated",
                source_id: .id,
                agent_id: .agentId,
                name: .name,
                enabled: true,
                kind: "cron",
                cron_expr: .schedule.expr,
                tz: (.schedule.tz // "UTC"),
                payload_kind: (.payload.kind // "agentTurn"),
                payload_message: (.payload.message // ""),
                model: (.payload.model // null),
                session_target: (.sessionTarget // "isolated"),
                wake_mode: (.wakeMode // "next-heartbeat"),
                imported_at: ($now | tonumber),
                next_run: 0,
                command: ("send @" + .agentId + " !task " + (.name | tojson)),
                full_command: ""
            }
        ]
    ' "$src" 2>/dev/null)

    portable=$(echo "$new_entries" | jq 'length' 2>/dev/null || echo 0)

    # Count non-portable enabled jobs (no cron expr or empty)
    nonportable=$(jq '[.jobs[] | select(.enabled == true) | select(.schedule.kind != "cron" or .schedule.expr == null or .schedule.expr == "")] | length' "$src" 2>/dev/null || echo 0)

    if [[ "$portable" -eq 0 ]]; then
        warn "  No portable jobs (need kind=cron + non-empty expr)"
    fi

    # Merge: drop any previously-imported entries with the same source_id,
    # then append new ones. Preserves any non-openclaw native schedule entries.
    local merged
    merged=$(jq --argjson new "$new_entries" '
        [.[] | select(.source != "openclaw-migrated" or .source_id == null)]
        + $new
    ' "$dst" 2>/dev/null)

    if [[ -n "$merged" ]]; then
        echo "$merged" > "$dst"
        ok "Imported $portable cron jobs → $dst (skipped $nonportable enabled non-cron + $disabled disabled)"
    else
        err "Failed to merge new jobs into $dst"
        return 1
    fi

    # Print a summary of what was imported (name + expression + tz)
    echo "$new_entries" | jq -r '.[] | "    [\(.agent_id)] \(.name) — \(.cron_expr) (\(.tz))"' 2>/dev/null
}

# =============================================================================
# Skills migration (~/.openclaw/skills -> ~/.metasphere/skills)
# =============================================================================

migrate_skills() {
    info "Migrating openclaw skills..."

    local src="$OPENCLAW_DIR/skills"
    local dst="$METASPHERE_DIR/skills"

    if [[ ! -d "$src" ]]; then
        info "No openclaw skills directory found"
        return 0
    fi

    mkdir -p "$dst"
    local migrated=0
    for skill in "$src"/*/; do
        [[ -d "$skill" ]] || continue
        local name=$(basename "$skill")
        # Skip _disabled directory
        [[ "$name" == _* ]] && continue
        if [[ ! -e "$dst/$name" ]]; then
            # Symlink rather than copy - keeps openclaw and metasphere in sync
            ln -s "$skill" "$dst/$name" 2>/dev/null && migrated=$((migrated + 1))
        fi
    done

    if [[ $migrated -gt 0 ]]; then
        ok "Linked $migrated openclaw skills into $dst"
    else
        info "No new skills to link (all already present)"
    fi
}

# =============================================================================
# Memory migration
# =============================================================================

migrate_memory() {
    info "Registering openclaw memory store..."

    mkdir -p "$METASPHERE_DIR/memory"

    # Canonical openclaw memory: ~/.openclaw/memory/main.sqlite
    if [[ -f "$OPENCLAW_DIR/memory/main.sqlite" ]]; then
        # Don't copy - register the path so CAM/FTS can read it in place.
        echo "$OPENCLAW_DIR/memory/main.sqlite" > "$METASPHERE_DIR/config/openclaw_memory_db"
        ok "Registered openclaw memory db: $OPENCLAW_DIR/memory/main.sqlite"
    fi

    # Pre-sqlite era: loose memory files
    local migrated=0
    shopt -s nullglob
    for mem in "$OPENCLAW_DIR"/*.memory "$OPENCLAW_DIR"/memory.json "$OPENCLAW_DIR"/agents/*/memory.json; do
        [[ -f "$mem" ]] || continue
        local basename=$(basename "$mem")
        local target="$METASPHERE_DIR/memory/$basename"
        cp "$mem" "$target"
        migrated=$((migrated + 1))
    done
    shopt -u nullglob

    [[ $migrated -gt 0 ]] && ok "Also migrated $migrated legacy memory files"
}

# =============================================================================
# Session parsing with CAM
# =============================================================================

parse_sessions() {
    info "Parsing sessions with CAM..."

    # Find cam binary - it may not be on the systemd-run PATH even if installed
    local cam_bin=""
    if command -v cam &>/dev/null; then
        cam_bin=$(command -v cam)
    else
        for c in "$HOME/.local/bin/cam" /usr/local/bin/cam /opt/homebrew/bin/cam; do
            [[ -x "$c" ]] && { cam_bin="$c"; break; }
        done
    fi

    if [[ -z "$cam_bin" ]]; then
        warn "CAM not installed - skipping session parsing"
        echo "    Install: pipx install collective-agent-memory"
        return 1
    fi

    # Index any new sessions
    "$cam_bin" index 2>&1 | grep -v "^$" | head -5 || true

    # Show status
    local segment_count=$("$cam_bin" status 2>/dev/null | grep -o "[0-9]* segments" | head -1 || echo "unknown")
    ok "CAM indexed sessions ($segment_count)"
}

# =============================================================================
# Disable OpenClaw
# =============================================================================

disable_openclaw() {
    info "Disabling OpenClaw gateway..."

    if [[ "$(uname)" == "Darwin" ]]; then
        local plist="$HOME/Library/LaunchAgents/com.openclaw.gateway.plist"
        if [[ -f "$plist" ]]; then
            launchctl unload "$plist" 2>/dev/null || true
            mv "$plist" "${plist}.disabled"
            ok "Disabled OpenClaw launchd service"
        else
            info "No OpenClaw launchd service found"
        fi
    else
        if systemctl --user is-active openclaw-gateway &>/dev/null; then
            systemctl --user stop openclaw-gateway
            systemctl --user disable openclaw-gateway
            ok "Disabled OpenClaw systemd service"
        else
            info "No OpenClaw systemd service running"
        fi
    fi

    # Mark as disabled in config
    if [[ -f "$OPENCLAW_DIR/openclaw.json" ]]; then
        local tmp=$(mktemp)
        jq '. + {metasphere_migrated: true, gateway_disabled: true}' "$OPENCLAW_DIR/openclaw.json" > "$tmp"
        mv "$tmp" "$OPENCLAW_DIR/openclaw.json"
        ok "Marked OpenClaw config as migrated"
    fi
}

# =============================================================================
# Full migration
# =============================================================================

run_migration() {
    local disable_openclaw_flag=false

    for arg in "$@"; do
        case "$arg" in
            --disable) disable_openclaw_flag=true ;;
        esac
    done

    echo "Metasphere Migration"
    echo "===================="
    echo
    echo "Source: $OPENCLAW_DIR"
    echo "Target: $METASPHERE_DIR"
    echo

    # Check if already migrated
    if [[ -f "$OPENCLAW_DIR/openclaw.json" ]]; then
        if jq -e '.metasphere_migrated' "$OPENCLAW_DIR/openclaw.json" &>/dev/null; then
            warn "Already migrated - running again may overwrite changes"
            echo
        fi
    fi

    # Ensure config dir exists - migration steps write registration files here
    mkdir -p "$METASPHERE_DIR/config"

    # Run migration steps
    migrate_telegram || true
    migrate_soul || true
    migrate_skills || true
    migrate_memory || true
    migrate_cron || true
    parse_sessions || true

    # Optionally disable OpenClaw
    if $disable_openclaw_flag; then
        disable_openclaw
    fi

    # Log migration event
    "$SCRIPT_DIR/metasphere-events" log migration.complete "Migrated from OpenClaw" --agent @system 2>/dev/null || true

    echo
    echo "Migration complete!"
    echo "==================="
    echo
    echo "Next steps:"
    echo "  1. Start Metasphere: metasphere daemon start"
    echo "  2. Check status: metasphere status"
    if ! $disable_openclaw_flag; then
        echo "  3. Disable OpenClaw: metasphere-migrate disable"
    fi
}

# =============================================================================
# Interactive disable prompt
# =============================================================================

prompt_disable() {
    echo "Disable OpenClaw Gateway?"
    echo "========================="
    echo
    echo "This will:"
    echo "  - Stop the OpenClaw gateway service"
    echo "  - Disable it from starting on boot"
    echo "  - Mark the config as migrated"
    echo
    echo "OpenClaw data will NOT be deleted."
    echo

    read -p "Disable OpenClaw gateway? [y/N] " -n 1 -r
    echo

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        disable_openclaw
    else
        info "Skipped - OpenClaw gateway still running"
    fi
}

# =============================================================================
# Main
# =============================================================================

case "${1:-detect}" in
    detect|check)
        detect_openclaw
        ;;
    run|migrate)
        shift
        run_migration "$@"
        ;;
    telegram|token)
        migrate_telegram
        ;;
    sessions|cam)
        parse_sessions
        ;;
    disable|stop)
        if [[ "${2:-}" == "-y" || "${2:-}" == "--yes" ]]; then
            disable_openclaw
        else
            prompt_disable
        fi
        ;;
    *)
        cat << 'EOF'
metasphere-migrate - OpenClaw to Metasphere migration

Usage:
  metasphere-migrate detect            Check for OpenClaw installation
  metasphere-migrate run [--disable]   Run full migration
  metasphere-migrate telegram          Extract Telegram token only
  metasphere-migrate sessions          Parse sessions with CAM
  metasphere-migrate disable [-y]      Disable OpenClaw gateway

The migration will:
  - Extract Telegram bot token from openclaw.json
  - Copy SOUL.md and agent profiles
  - Import memory files
  - Trigger CAM to index sessions

Use --disable with 'run' to also disable OpenClaw after migration.
EOF
        exit 1
        ;;
esac
