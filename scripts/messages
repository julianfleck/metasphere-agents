#!/bin/bash
# messages - Fractal inter-agent messaging CLI
#
# Messages are scoped by directory tree:
#   - Each directory has .messages/inbox/ and .messages/outbox/
#   - Agents see messages in their scope + parent scopes (upward visibility)
#   - Agents can send up (parent), down (children), or lateral (siblings)
#
# Message addressing:
#   @.           = current scope (pwd)
#   @..          = parent scope
#   @/path/to/   = absolute path scope
#   @agent-name  = named agent (resolves via ~/.metasphere/agents/)
#
# Usage:
#   messages                                    # Show inbox (precommand hook)
#   messages send @target !label "message"      # Send message
#   messages reply <msg-id> "response"          # Reply to message
#   messages done <msg-id> "completion note"    # Mark task complete
#   messages status [msg-id]                    # Show/update message status
#   messages tree                               # Show message tree (scope hierarchy)

set -e

REPO_ROOT="${METASPHERE_PROJECT_ROOT:-${METASPHERE_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}}"
METASPHERE_DIR="${METASPHERE_DIR:-$HOME/.metasphere}"
source "$(dirname "$0")/metasphere-identity"
AGENT="$(resolve_agent_id)"
SCOPE="${METASPHERE_SCOPE:-$REPO_ROOT}"

# Ensure we're in a valid scope
cd "$SCOPE" 2>/dev/null || cd "$REPO_ROOT"
SCOPE="$(pwd)"

# Colors (disabled if not terminal)
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    YELLOW='\033[1;33m'
    GREEN='\033[0;32m'
    CYAN='\033[0;36m'
    DIM='\033[2m'
    BOLD='\033[1m'
    NC='\033[0m'
else
    RED='' YELLOW='' GREEN='' CYAN='' DIM='' BOLD='' NC=''
fi

# Generate message ID
gen_msg_id() {
    echo "msg-$(date +%s)-$$"
}

# Get relative path from repo root
rel_path() {
    local path="$1"
    echo "${path#$REPO_ROOT}" | sed 's|^/*|/|'
}

# Resolve target to absolute path
resolve_target() {
    local target="$1"

    case "$target" in
        @.)
            echo "$SCOPE"
            ;;
        @..)
            dirname "$SCOPE"
            ;;
        @/*)
            # Absolute path from repo root
            echo "$REPO_ROOT${target#@}"
            ;;
        @*)
            # Named agent - check if it has a registered scope
            local agent_name="${target#@}"
            local agent_scope="$METASPHERE_DIR/agents/$target/scope"
            if [[ -f "$agent_scope" ]]; then
                cat "$agent_scope"
            else
                # Default to root scope for named agents
                echo "$REPO_ROOT"
            fi
            ;;
        *)
            echo "$SCOPE"
            ;;
    esac
}

# Create message file with YAML frontmatter
create_message() {
    local id="$1"
    local from="$2"
    local to="$3"
    local label="$4"
    local body="$5"
    local scope="$6"
    local timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    local reply_to="${7:-}"

    cat << EOF
---
id: $id
from: $from
to: $to
label: $label
status: unread
scope: $(rel_path "$scope")
created: $timestamp
read_at:
replied_at:
completed_at:
reply_to: $reply_to
---

$body
EOF
}

# Parse message field
msg_field() {
    local file="$1"
    local field="$2"
    grep "^${field}:" "$file" 2>/dev/null | head -1 | sed "s/^${field}: *//"
}

# Update message status
update_msg_status() {
    local file="$1"
    local field="$2"
    local value="$3"

    if [[ "$(uname)" == "Darwin" ]]; then
        sed -i '' "s/^${field}:.*/${field}: ${value}/" "$file"
    else
        sed -i "s/^${field}:.*/${field}: ${value}/" "$file"
    fi
}

# Collect messages from scope and parent scopes (upward visibility)
collect_inbox() {
    local current="$SCOPE"
    local messages=()

    # Walk up the tree to repo root
    while [[ "$current" == "$REPO_ROOT"* ]]; do
        local inbox="$current/.messages/inbox"
        if [[ -d "$inbox" ]]; then
            shopt -s nullglob; for msg in "$inbox"/*.msg; do
                [[ -f "$msg" ]] && messages+=("$msg")
            done
        fi

        # Stop at repo root
        [[ "$current" == "$REPO_ROOT" ]] && break
        current="$(dirname "$current")"
    done

    printf '%s\n' "${messages[@]}" | sort -r
}

cmd_inbox() {
    local show_all="${1:-}"
    local messages=($(collect_inbox))
    local unread=0
    local total=${#messages[@]}

    # Count unread
    for msg in "${messages[@]}"; do
        [[ -f "$msg" ]] && [[ "$(msg_field "$msg" status)" == "unread" ]] && unread=$((unread + 1))
    done

    if [[ $total -eq 0 ]]; then
        echo "## Messages: No messages in scope"
        return
    fi

    echo "## Messages ($unread unread, $total total)"
    echo "## Scope: $(rel_path "$SCOPE")"
    echo ""

    for msg in "${messages[@]}"; do
        [[ -f "$msg" ]] || continue

        local id=$(msg_field "$msg" id)
        local from=$(msg_field "$msg" from)
        local label=$(msg_field "$msg" label)
        local status=$(msg_field "$msg" status)
        local created=$(msg_field "$msg" created)
        local msg_scope=$(msg_field "$msg" scope)
        local reply_to=$(msg_field "$msg" reply_to)

        # Get body (everything after the --- delimiter)
        local body=$(awk '/^---$/{p++; next} p==2{print}' "$msg" | head -3 | tr '\n' ' ' | cut -c1-60)

        # Skip read messages unless show_all
        [[ -z "$show_all" && "$status" != "unread" ]] && continue

        # Status indicator
        local status_icon=""
        case "$status" in
            unread)    status_icon="○" ;;
            read)      status_icon="◐" ;;
            replied)   status_icon="◑" ;;
            completed) status_icon="●" ;;
        esac

        # Label coloring
        local label_display="$label"
        case "$label" in
            !urgent) label_display="${RED}$label${NC}" ;;
            !task)   label_display="${YELLOW}$label${NC}" ;;
            !done)   label_display="${GREEN}$label${NC}" ;;
            !query)  label_display="${CYAN}$label${NC}" ;;
        esac

        # Reply indicator
        local reply_indicator=""
        [[ -n "$reply_to" ]] && reply_indicator=" ${DIM}↩ reply to $reply_to${NC}"

        echo -e "$status_icon $label_display from $from ${DIM}[$id]${NC}$reply_indicator"
        echo -e "  ${DIM}$msg_scope | $created${NC}"
        echo "  $body"
        echo ""
    done
}

cmd_send() {
    local target="$1"
    local label="$2"
    shift 2
    local message="$*"

    if [[ -z "$target" || -z "$label" || -z "$message" ]]; then
        echo "Usage: messages send @target !label \"message\""
        echo ""
        echo "Targets:"
        echo "  @.        Current scope"
        echo "  @..       Parent scope"
        echo "  @/path/   Absolute path scope"
        echo "  @name     Named agent"
        exit 1
    fi

    local target_path=$(resolve_target "$target")
    local target_inbox="$target_path/.messages/inbox"
    local my_outbox="$SCOPE/.messages/outbox"

    mkdir -p "$target_inbox" "$my_outbox"

    local msg_id=$(gen_msg_id)
    local msg_file="$target_inbox/${msg_id}.msg"
    local out_file="$my_outbox/${msg_id}.msg"

    create_message "$msg_id" "$AGENT" "$target" "$label" "$message" "$target_path" > "$msg_file"
    cp "$msg_file" "$out_file"

    # Log event and track activity
    local script_dir="$(cd "$(dirname "$0")" && pwd)"
    "$script_dir/metasphere-events" log message.send "$AGENT → $target: $label" --agent "$AGENT" --meta msg_id="$msg_id" >/dev/null 2>&1 || true
    "$script_dir/metasphere-agent" activity --sent >/dev/null 2>&1 || true

    echo "Sent $msg_id to $target ($(rel_path "$target_path"))"
    echo "  Label: $label"

    # Wake the recipient if it has a live tmux session. Without this, a
    # parent agent sitting idle in its REPL never sees that a child sent
    # a !done message — the message lands in the inbox but no turn fires
    # to read it. The whole "fractal coordination" story depends on this.
    #
    # EXCEPTION: when the sender is @user, the wake is already handled
    # by metasphere-telegram-stream's inject_to_orchestrator (which runs
    # before the messages CLI even gets called via the bot's process
    # path). Calling submit_to_tmux a second time produces double-wakes
    # (Julian observed this). Skip when AGENT==@user.
    if [[ "$AGENT" != "@user" ]]; then
        wake_recipient_if_live "$target" "$label" "$AGENT" "$message" || true
    fi
}

# Resolve a recipient address to its tmux session name (if any), then
# inject a brief wake notice into that session via submit_to_tmux.
#
# Convention: every persistent agent in tmux gets a session named
# "metasphere-<agent-name>" (without the @). The orchestrator is at
# "metasphere-orchestrator". @.., @/path/, @name all eventually resolve
# to either an agent name or a scope path; we wake the agent we can find.
wake_recipient_if_live() {
    local target="$1"
    local label="$2"
    local from="$3"
    local body="$4"

    local script_dir
    script_dir="$(cd "$(dirname "$0")" && pwd)"

    # Resolve target to an agent name when possible.
    local agent_name=""
    case "$target" in
        @..)
            # Parent scope — most common case is @orchestrator at repo root.
            local parent_scope; parent_scope=$(dirname "$SCOPE")
            if [[ "$parent_scope" == "$REPO_ROOT" || "$SCOPE" == "$REPO_ROOT" ]]; then
                agent_name="orchestrator"
            fi
            ;;
        @.|@/*|"")
            # Scope-targeted, not agent-targeted. Try to wake the orchestrator
            # if the scope is the repo root, since that's where it lives.
            local resolved; resolved=$(resolve_target "$target")
            if [[ "$resolved" == "$REPO_ROOT" ]]; then
                agent_name="orchestrator"
            fi
            ;;
        @*)
            agent_name="${target#@}"
            ;;
    esac

    [[ -z "$agent_name" ]] && return 0

    # Find tmux. If not present, nothing to wake.
    local tmux_bin=""
    tmux_bin=$(command -v tmux 2>/dev/null) || return 0

    local session="metasphere-${agent_name}"
    "$tmux_bin" has-session -t "$session" 2>/dev/null || return 0

    # Build a tight, action-imperative wake notice. Truncate body to ~200
    # chars so we don't dump the full message into the prompt buffer.
    local body_preview="${body:0:200}"
    [[ ${#body} -gt 200 ]] && body_preview="${body_preview}..."

    local notice="[wake] new ${label} from ${from}: ${body_preview}"

    # Use submit_to_tmux to inject. Source the helper so we can call it.
    if [[ -r "$script_dir/metasphere-tmux-submit" ]]; then
        # shellcheck disable=SC1090
        source "$script_dir/metasphere-tmux-submit"
        TMUX_CMD="$tmux_bin" submit_to_tmux "$session" "$notice" >/dev/null 2>&1 || true
    fi

    # Log the wake so it shows up in events
    "$script_dir/metasphere-events" log agent.wake "@${agent_name} woken by ${from} (${label})" --agent "$from" >/dev/null 2>&1 || true
}

cmd_reply() {
    local orig_id="$1"
    shift
    local message="$*"

    if [[ -z "$orig_id" || -z "$message" ]]; then
        echo "Usage: messages reply <msg-id> \"response\""
        exit 1
    fi

    # Find original message
    local orig_msg=$(find "$REPO_ROOT" -path "*/.messages/inbox/${orig_id}.msg" 2>/dev/null | head -1)

    if [[ -z "$orig_msg" ]]; then
        echo "Message $orig_id not found"
        exit 1
    fi

    local from=$(msg_field "$orig_msg" from)
    local orig_scope=$(msg_field "$orig_msg" scope)

    # Mark original as replied
    update_msg_status "$orig_msg" "status" "replied"
    update_msg_status "$orig_msg" "replied_at" "$(date -u +%Y-%m-%dT%H:%M:%SZ)"

    # Send reply to original sender's scope
    local target_path=$(resolve_target "$from")
    local target_inbox="$target_path/.messages/inbox"
    local my_outbox="$SCOPE/.messages/outbox"

    mkdir -p "$target_inbox" "$my_outbox"

    local msg_id=$(gen_msg_id)
    local msg_file="$target_inbox/${msg_id}.msg"
    local out_file="$my_outbox/${msg_id}.msg"

    create_message "$msg_id" "$AGENT" "$from" "!reply" "$message" "$target_path" "$orig_id" > "$msg_file"
    cp "$msg_file" "$out_file"

    # Track activity
    local script_dir="$(cd "$(dirname "$0")" && pwd)"
    "$script_dir/metasphere-agent" activity --sent >/dev/null 2>&1 || true

    echo "Replied to $orig_id → $msg_id"
}

cmd_done() {
    local orig_id="$1"
    shift
    local note="$*"

    if [[ -z "$orig_id" ]]; then
        echo "Usage: messages done <msg-id> [\"completion note\"]"
        exit 1
    fi

    # Find original message
    local orig_msg=$(find "$REPO_ROOT" -path "*/.messages/inbox/${orig_id}.msg" 2>/dev/null | head -1)

    if [[ -z "$orig_msg" ]]; then
        echo "Message $orig_id not found"
        exit 1
    fi

    local from=$(msg_field "$orig_msg" from)

    # Mark original as completed
    update_msg_status "$orig_msg" "status" "completed"
    update_msg_status "$orig_msg" "completed_at" "$(date -u +%Y-%m-%dT%H:%M:%SZ)"

    # Skip self-notification: when the original sender is the same agent
    # running `messages done`, sending a !done back to ourselves spawns a
    # notification that the consolidator then ages into STALE and pings,
    # producing a self-sustaining loop (loop 1: @orch → @orch self-notify).
    # The original message is already marked completed above; that's all
    # the bookkeeping needed.
    if [[ -n "$note" && "$from" == "$AGENT" ]]; then
        echo "Completed $orig_id (skip self-notify)"
        return
    fi

    # Send done notification if note provided
    if [[ -n "$note" ]]; then
        local target_path=$(resolve_target "$from")
        local target_inbox="$target_path/.messages/inbox"
        mkdir -p "$target_inbox"

        local msg_id=$(gen_msg_id)
        create_message "$msg_id" "$AGENT" "$from" "!done" "$note" "$target_path" "$orig_id" > "$target_inbox/${msg_id}.msg"

        # Track activity
        local script_dir="$(cd "$(dirname "$0")" && pwd)"
        "$script_dir/metasphere-agent" activity --sent >/dev/null 2>&1 || true

        echo "Completed $orig_id, notified $from → $msg_id"
    else
        echo "Completed $orig_id"
    fi
}

cmd_read_msg() {
    local msg_id="$1"

    # Find message
    local msg=$(find "$REPO_ROOT" -path "*/.messages/inbox/${msg_id}.msg" 2>/dev/null | head -1)

    if [[ -z "$msg" ]]; then
        echo "Message $msg_id not found"
        exit 1
    fi

    # Mark as read
    if [[ "$(msg_field "$msg" status)" == "unread" ]]; then
        update_msg_status "$msg" "status" "read"
        update_msg_status "$msg" "read_at" "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    fi

    cat "$msg"
}

cmd_tree() {
    echo "## Message Tree"
    echo "## Scope: $(rel_path "$SCOPE")"
    echo ""

    find "$REPO_ROOT" -type d -name ".messages" 2>/dev/null | while read -r msg_dir; do
        local scope_dir=$(dirname "$msg_dir")
        local rel=$(rel_path "$scope_dir")
        local inbox_count=$(find "$msg_dir/inbox" -name "*.msg" 2>/dev/null | wc -l | tr -d ' ')
        local outbox_count=$(find "$msg_dir/outbox" -name "*.msg" 2>/dev/null | wc -l | tr -d ' ')

        [[ $inbox_count -eq 0 && $outbox_count -eq 0 ]] && continue

        # Indicate current scope
        local marker=""
        [[ "$scope_dir" == "$SCOPE" ]] && marker=" ← you are here"

        echo "$rel$marker"
        echo "  inbox: $inbox_count | outbox: $outbox_count"
    done
}

cmd_status() {
    local msg_id="$1"

    if [[ -z "$msg_id" ]]; then
        # Show all agents' status
        echo "## Agent Status"
        for status_file in "$METASPHERE_DIR/agents"/*/status; do
            [[ -f "$status_file" ]] || continue
            local agent=$(basename "$(dirname "$status_file")")
            local status=$(cat "$status_file")
            echo "- $agent: $status"
        done
    else
        # Show specific message status
        local msg=$(find "$REPO_ROOT" -path "*/.messages/*/${msg_id}.msg" 2>/dev/null | head -1)
        if [[ -z "$msg" ]]; then
            echo "Message $msg_id not found"
            exit 1
        fi

        echo "Message: $msg_id"
        echo "Status: $(msg_field "$msg" status)"
        echo "Created: $(msg_field "$msg" created)"
        echo "Read: $(msg_field "$msg" read_at)"
        echo "Replied: $(msg_field "$msg" replied_at)"
        echo "Completed: $(msg_field "$msg" completed_at)"
    fi
}

# Main command dispatch
case "${1:-}" in
    "")
        cmd_inbox
        ;;
    all)
        cmd_inbox "all"
        ;;
    send)
        shift
        cmd_send "$@"
        ;;
    reply)
        shift
        cmd_reply "$@"
        ;;
    done)
        shift
        cmd_done "$@"
        ;;
    read)
        shift
        cmd_read_msg "$@"
        ;;
    tree)
        cmd_tree
        ;;
    status)
        shift
        cmd_status "$@"
        ;;
    *)
        cat << 'EOF'
messages - Fractal inter-agent messaging

Usage:
  messages                              Show unread messages (precommand hook)
  messages all                          Show all messages including read
  messages send @target !label "msg"    Send message
  messages reply <msg-id> "response"    Reply to message (marks original as replied)
  messages done <msg-id> "note"         Mark task complete, notify sender
  messages read <msg-id>                Read full message (marks as read)
  messages tree                         Show message tree across scopes
  messages status [msg-id]              Show agent or message status

Targets:
  @.        Current directory scope
  @..       Parent directory scope
  @/path/   Absolute path from repo root
  @name     Named agent (from ~/.metasphere/agents/)

Labels:
  !task     Task assignment
  !urgent   Requires immediate attention
  !info     Informational
  !query    Asking for information
  !done     Task completion
  !reply    Reply to previous message

Scoping:
  Messages are stored in .messages/inbox/ at each directory level.
  Agents see messages in their scope + all parent scopes (upward visibility).
EOF
        exit 1
        ;;
esac
