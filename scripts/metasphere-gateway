#!/bin/bash
# metasphere-gateway - Persistent session orchestrator with watchdog
#
# Architecture:
#   - Maintains persistent tmux session for @orchestrator
#   - User messages are injected INTO the session (not spawning new ones)
#   - Watchdog monitors session health and revives if needed
#   - Responses are captured and sent to Telegram
#
# Session modes:
#   - persistent (default): Single long-running session, messages injected
#   - per-message: Fresh session per message (original behavior)
#
# Usage:
#   metasphere-gateway daemon [interval]   Run gateway with watchdog
#   metasphere-gateway inject "message"    Send message to orchestrator session
#   metasphere-gateway ensure              Ensure session is alive
#   metasphere-gateway status              Check session status

set -e

METASPHERE_DIR="${METASPHERE_DIR:-$HOME/.metasphere}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Resolve REPO_ROOT carefully - avoid home directory
resolve_repo_root() {
    if [[ -n "$METASPHERE_REPO_ROOT" ]]; then
        echo "$METASPHERE_REPO_ROOT"
        return
    fi
    local git_root=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
    if [[ -n "$git_root" && "$git_root" != "$HOME" ]]; then
        echo "$git_root"
        return
    fi
    # Fallbacks for when daemon runs without a cwd inside the repo (e.g. launchctl)
    for candidate in "$HOME/Code/metasphere-agents" "$HOME/code/metasphere-agents" "$PWD"; do
        if [[ -d "$candidate/.claude" || -d "$candidate/scripts" ]]; then
            echo "$candidate"
            return
        fi
    done
    echo "$PWD"
}
REPO_ROOT=$(resolve_repo_root)

# Load Telegram config
[[ -f "$METASPHERE_DIR/config/telegram.env" ]] && source "$METASPHERE_DIR/config/telegram.env"
[[ -f "$METASPHERE_DIR/config/telegram_chat_id" ]] && TELEGRAM_CHAT_ID=$(cat "$METASPHERE_DIR/config/telegram_chat_id")

# Load timezone config (user's preferred timezone, system runs on UTC)
USER_TIMEZONE="${METASPHERE_TIMEZONE:-}"
[[ -f "$METASPHERE_DIR/config/timezone" ]] && USER_TIMEZONE=$(cat "$METASPHERE_DIR/config/timezone")

# Format timestamp with both UTC and user timezone
format_timestamp() {
    local utc_ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    if [[ -n "$USER_TIMEZONE" ]]; then
        local local_ts=$(TZ="$USER_TIMEZONE" date +%H:%M 2>/dev/null || echo "")
        if [[ -n "$local_ts" ]]; then
            echo "$utc_ts ($local_ts $USER_TIMEZONE)"
        else
            echo "$utc_ts"
        fi
    else
        echo "$utc_ts"
    fi
}

# Session config
SESSION_NAME="metasphere-orchestrator"
SESSION_MODE="${METASPHERE_SESSION_MODE:-persistent}"
RESPONSE_FILE="$METASPHERE_DIR/gateway/pending_response"
OFFSET_FILE="$METASPHERE_DIR/telegram/offset"
LOG_FILE="$METASPHERE_DIR/logs/gateway.log"
SUPERVISOR_LOG="$METASPHERE_DIR/logs/supervisor.log"
CONFIG_MTIME_FILE="$METASPHERE_DIR/state/last_config_mtime"
STUCK_PASTE_STATE="$METASPHERE_DIR/state/stuck_paste_seen"

# Files to watch for config changes - if any change, restart claude in session
WATCHED_CONFIG_FILES=(
    "$REPO_ROOT/.claude/settings.local.json"
    "$REPO_ROOT/.claude/settings.json"
    "$REPO_ROOT/scripts/metasphere-context"
    "$REPO_ROOT/scripts/metasphere-tmux-submit"
)

mkdir -p "$METASPHERE_DIR/logs" "$METASPHERE_DIR/telegram" "$METASPHERE_DIR/gateway" "$METASPHERE_DIR/state"

supervisor_log() {
    echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $*" >> "$SUPERVISOR_LOG"
}

# Source the reliable tmux submit helper (provides submit_to_tmux + tmux_submit_watchdog)
# shellcheck source=/dev/null
source "$SCRIPT_DIR/metasphere-tmux-submit"

# Find tmux - use which first, then fall back to known paths
TMUX_CMD=$(which tmux 2>/dev/null || true)
if [[ -z "$TMUX_CMD" ]]; then
    # Fall back to known paths
    for path in /opt/homebrew/bin/tmux /usr/local/bin/tmux /usr/bin/tmux; do
        if [[ -x "$path" ]]; then
            TMUX_CMD="$path"
            break
        fi
    done
fi
# Last resort: check Homebrew Cellar (installed but not linked)
if [[ -z "$TMUX_CMD" && -d "/opt/homebrew/Cellar/tmux" ]]; then
    TMUX_CMD=$(find /opt/homebrew/Cellar/tmux -name "tmux" -type f -perm +111 2>/dev/null | head -1)
fi

# Fall back to per-message mode if tmux not found
if [[ -z "$TMUX_CMD" ]]; then
    if [[ "$SESSION_MODE" == "persistent" ]]; then
        echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] tmux not found, falling back to per-message mode" >> "$LOG_FILE"
        SESSION_MODE="per-message"
    fi
else
    echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] Using tmux: $TMUX_CMD" >> "$LOG_FILE"
fi

log() {
    echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $*" | tee -a "$LOG_FILE"
}

# =============================================================================
# Session Management
# =============================================================================

# Check if orchestrator session exists and is healthy
session_alive() {
    $TMUX_CMD has-session -t "$SESSION_NAME" 2>/dev/null
}

# Get session info
session_info() {
    if session_alive; then
        local created=$($TMUX_CMD display-message -t "$SESSION_NAME" -p '#{session_created}' 2>/dev/null)
        local activity=$($TMUX_CMD display-message -t "$SESSION_NAME" -p '#{session_activity}' 2>/dev/null)
        echo "alive created=$created last_activity=$activity"
    else
        echo "dead"
    fi
}

# Build initial context for new session
build_initial_context() {
    cat << 'CONTEXT'
# Orchestrator Session

You are @orchestrator in a persistent session. You will receive user messages and system events continuously.

## Your Role
- Respond to user messages via Telegram
- Coordinate other agents
- Monitor system health
- Take proactive action when needed

## How This Works
- User messages appear as "## User Message" blocks
- Respond naturally - your output goes to Telegram
- Use tools as needed for actions
- Session persists - you have continuity

## Available Commands

### Status & Overview
- metasphere status              # Full system status
- metasphere ls                  # Project landscape (agents, tasks, events)
- metasphere ls @agent           # Agent-specific view
- metasphere agents              # List all agents
- metasphere logs                # View all logs
- metasphere logs gateway -f     # Follow gateway log
- metasphere logs events -f      # Follow event stream

### Tasks
- tasks                          # List active tasks
- tasks new "title" !priority    # Create task (!urgent, !high, !normal, !low)
- tasks start ID                 # Start working on task
- tasks update ID "note"         # Add update
- tasks done ID "summary"        # Complete task
- tasks tree                     # Show task tree across scopes

### Messages
- messages send @target !label "msg"   # Send to agent
- messages inbox                       # Check inbox
- messages read ID                     # Read message

### Agents
- metasphere agent spawn @name --task "X" --sandbox scoped
- metasphere agent status @name
- metasphere agent update @name --status "working: X"
- metasphere agent sunset @name        # Graceful shutdown with learnings
- metasphere agent tree                # Show agent hierarchy
- metasphere agent subtree @name       # Show agent's descendants
- metasphere agent report @name "msg"  # Bubble up to parent

### Events
- metasphere events log TYPE "msg" --agent @name
- metasphere events tail 20            # Recent events
- metasphere events query --type task  # Filter events

### Projects
- metasphere project init [path]       # Initialize project
- metasphere project list              # List projects
- metasphere project status            # Project status
- metasphere project changelog         # Generate changelog
- metasphere project learnings         # Aggregate learnings

### Scheduling
- metasphere schedule                  # List jobs
- metasphere schedule add 'cmd' @15:00 @daily

### Telegram
- metasphere-telegram-stream send "msg"  # Send to Telegram

## Guidelines
- Be concise (Telegram has 4000 char limit)
- No emojis
- Give specifics, not high-level summaries
- Check events for recent activity
- Proactively communicate blockers
- Use tasks to track work
- Spawn child agents for parallel work

Ready for messages.
CONTEXT

    # Persona / identity / openclaw workspace files are NOT inlined.
    # We list them as @-paths so claude-code reads them lazily on demand
    # via its native @file mention handling. Inlining was a mistake — it
    # blasted ~50KB of literal-mode keystrokes into the pane on every
    # session start, dominated context, and on a slow tmux paste loop
    # took over a minute to type.
    local openclaw_ws=""
    if [[ -f "$METASPHERE_DIR/config/openclaw_workspace" ]]; then
        openclaw_ws=$(cat "$METASPHERE_DIR/config/openclaw_workspace" 2>/dev/null)
    elif [[ -d "$HOME/.openclaw/workspace" ]]; then
        openclaw_ws="$HOME/.openclaw/workspace"
    fi

    local agent_dir="$METASPHERE_DIR/agents/${METASPHERE_AGENT_ID:-@orchestrator}"

    echo
    echo "## Identity & persona files (read on demand)"
    echo
    echo "Below are file paths to read with the Read tool when you need them."
    echo "Do NOT read them all up-front — only what's relevant to the current task."
    echo

    if [[ -n "$openclaw_ws" && -d "$openclaw_ws" ]]; then
        echo "**OpenClaw workspace** (\`$openclaw_ws\`):"
        for f in SOUL IDENTITY USER TOOLS AGENTS MEMORY; do
            [[ -f "$openclaw_ws/$f.md" ]] && echo "- $openclaw_ws/$f.md"
        done
        echo
    fi

    if [[ -d "$agent_dir" ]]; then
        echo "**Agent identity** (${METASPHERE_AGENT_ID:-@orchestrator}):"
        for f in MISSION HEARTBEAT LEARNINGS SOUL; do
            [[ -f "$agent_dir/$f.md" ]] && echo "- $agent_dir/$f.md"
        done
        echo
    fi

    echo "Tip: when a user's request touches your persona or operating rules,"
    echo "Read the relevant file. Otherwise leave them on disk."
}

# Start new orchestrator session
start_session() {
    log "Starting orchestrator session"

    local scope=$(cat "$METASPHERE_DIR/agents/@orchestrator/scope" 2>/dev/null || echo "$REPO_ROOT")

    # Create tmux session
    $TMUX_CMD new-session -d -s "$SESSION_NAME" -c "$scope"
    $TMUX_CMD set-option -t "$SESSION_NAME" mouse on
    $TMUX_CMD set-option -t "$SESSION_NAME" history-limit 100000

    # Record harness hash baseline so the per-turn context hook can detect
    # stale-context drift and surface it to the agent (which then decides
    # whether to /exit and self-reload).
    write_harness_hash_baseline

    # Start claude inside a self-respawning loop. When the agent runs /exit
    # (because it noticed its baked-in CLAUDE.md / hook is stale, or because
    # it explicitly wants a fresh context), claude returns to bash, the loop
    # sleeps a tick, and a brand-new claude REPL starts — picking up the
    # latest harness automatically. The host gateway is OUT of the cognition
    # control loop. tmux pane stays alive across REPL respawns, so external
    # attachers (spot-chat, mosh, etc) don't drop.
    $TMUX_CMD send-keys -t "$SESSION_NAME" \
      "exec bash -c 'while true; do claude --dangerously-skip-permissions; ec=\$?; echo \"[gateway] claude exited (\$ec), respawning in 1s...\"; sleep 1; done'" Enter

    sleep 3  # Wait for claude to initialize

    # NOTE: We deliberately do NOT inject build_initial_context into the
    # pane any more. claude-code auto-loads CLAUDE.md from the project
    # root on startup, which already contains the orchestrator role,
    # command reference, and persona file pointers. The per-turn
    # metasphere-context hook fills in deltas (messages, tasks, events)
    # before each turn. Inlining a multi-KB blob into the REPL via
    # literal-mode tmux typing locked the pane for over a minute and
    # immediately exhausted context. The agent can Read persona files
    # on demand using the @-paths CLAUDE.md lists.

    # Update agent status
    echo "active: persistent session" > "$METASPHERE_DIR/agents/@orchestrator/status"

    # Log event
    "$SCRIPT_DIR/metasphere-events" log agent.session "Orchestrator session started" --agent @orchestrator 2>/dev/null || true

    log "Session started: $SESSION_NAME"
}

# Ensure session is running
ensure_session() {
    if ! session_alive; then
        log "Session not alive, starting..."
        start_session
        return 0
    fi

    # Check if session is responsive (last activity within 5 min)
    local activity=$($TMUX_CMD display-message -t "$SESSION_NAME" -p '#{session_activity}' 2>/dev/null || echo "0")
    local now=$(date +%s)
    local age=$((now - activity))

    if [[ $age -gt 600 ]]; then
        log "Session stale (${age}s), checking health..."
        # Could add more sophisticated health check here
    fi

    return 0
}

# Inject message into session
inject_to_session() {
    local message="$1"

    if ! session_alive; then
        log "Session not alive for injection"
        return 1
    fi

    # Atomic paste + verified submit. submit_to_tmux handles the
    # paste-buffer + Enter race by polling capture-pane for the
    # "[Pasted text #N" placeholder and retrying Enter up to 3 times.
    TMUX_CMD="$TMUX_CMD" submit_to_tmux "$SESSION_NAME" "$message"
}

# =============================================================================
# Message Handling
# =============================================================================

# Build pre-command context (cam + metasphere ls)
build_precommand_context() {
    local context=""

    # CAM context (recent relevant sessions)
    if command -v cam &>/dev/null; then
        local cam_output=$(cam status 2>/dev/null | head -5 || echo "")
        if [[ -n "$cam_output" ]]; then
            context+="## Memory (CAM)
$cam_output
"
        fi
    fi

    # Metasphere landscape
    local ms_output=$("$SCRIPT_DIR/metasphere" ls 2>/dev/null | head -30 || echo "")
    if [[ -n "$ms_output" ]]; then
        context+="
## Metasphere Status
$ms_output
"
    fi

    echo "$context"
}

# Build context for a user message
build_message_context() {
    local trigger_message="$1"

    # Pre-command context
    local precommand=$(build_precommand_context)
    local timestamp=$(format_timestamp)

    cat << CONTEXT
$precommand
## User Message ($timestamp)
> $trigger_message

Respond to the user. Your response will be sent to Telegram.
CONTEXT
}

# Send response to Telegram
send_telegram() {
    local text="$1"

    [[ -z "$TELEGRAM_BOT_TOKEN" || -z "$TELEGRAM_CHAT_ID" ]] && {
        log "No Telegram config"
        return 1
    }

    # Truncate for Telegram limits
    text="${text:0:4000}"

    curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
        -d "chat_id=$TELEGRAM_CHAT_ID" \
        -d "parse_mode=Markdown" \
        --data-urlencode "text=$text" > /dev/null

    log "Sent to Telegram: ${text:0:50}..."
}

# Process incoming user message
process_user_message() {
    local text="$1"
    local message_id="$2"

    log "Processing: $text"

    # Log event
    "$SCRIPT_DIR/metasphere-events" log user.message "$text" --agent @user --meta msg_id="$message_id" 2>/dev/null || true

    if [[ "$SESSION_MODE" == "persistent" ]]; then
        # Inject into persistent session
        ensure_session
        local context=$(build_message_context "$text")
        inject_to_session "$context"

        # Wait for response (check tmux pane content)
        # This is tricky - we need to capture claude's response
        # For now, we rely on claude using the send command
        sleep 2  # Give time for processing

    else
        # Per-message mode (original behavior)
        local context=$(build_full_context "$text")
        local response=$(cd "$REPO_ROOT" && echo "$context" | claude -p --allowedTools "Read,Write,Edit,Bash,Glob,Grep" 2>&1 | tail -100)
        send_telegram "$response"
    fi
}

# Build full context for per-message mode
build_full_context() {
    local trigger_message="$1"

    # Pre-command context
    local precommand=$(build_precommand_context)

    cat << CONTEXT
# Orchestrator Session

You are @orchestrator. User sent a message - respond directly.

$precommand

## User Message
> $trigger_message

## Agent Tree
$(for d in "$METASPHERE_DIR/agents"/@*/; do
    [[ -d "$d" ]] || continue
    a=$(basename "$d")
    s=$(cat "$d/status" 2>/dev/null || echo "?")
    t=$(cat "$d/task" 2>/dev/null | head -c 60 || echo "none")
    echo "- $a: $s"
    echo "  Task: $t"
done)

## Recent Events
$("$SCRIPT_DIR/metasphere-events" tail 10 2>/dev/null || echo "none")

## Active Tasks
$("$SCRIPT_DIR/tasks" 2>/dev/null | head -15 || echo "none")

## How to Respond
- Answer with specifics
- No emojis
- Be concise

Your response will be sent to Telegram.
CONTEXT
}

# =============================================================================
# Telegram Polling
# =============================================================================

poll_telegram() {
    [[ -z "$TELEGRAM_BOT_TOKEN" ]] && return 1

    local offset=0
    [[ -f "$OFFSET_FILE" ]] && offset=$(cat "$OFFSET_FILE")

    local response=$(curl -s "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/getUpdates?offset=$offset&timeout=1")

    local ok=$(echo "$response" | jq -r '.ok')
    [[ "$ok" != "true" ]] && return 1

    echo "$response" | jq -c '.result[]' 2>/dev/null | while read -r update; do
        local update_id=$(echo "$update" | jq -r '.update_id')
        local message=$(echo "$update" | jq -c '.message // empty')

        if [[ -n "$message" && "$message" != "null" ]]; then
            local chat_id=$(echo "$message" | jq -r '.chat.id')
            local message_id=$(echo "$message" | jq -r '.message_id')
            local text=$(echo "$message" | jq -r '.text // ""')
            local from=$(echo "$message" | jq -r '.from.username // .from.first_name // "user"')

            # Save chat ID
            echo "$chat_id" > "$METASPHERE_DIR/config/telegram_chat_id"
            TELEGRAM_CHAT_ID="$chat_id"

            # Archive message
            "$SCRIPT_DIR/metasphere-telegram-stream" once 2>/dev/null || true

            # Process text messages
            if [[ -n "$text" && "$text" != "null" ]]; then
                log "[@$from] $text"

                if [[ "$text" == /* ]]; then
                    # Command - handle via telegram script
                    "$SCRIPT_DIR/metasphere-telegram" process "$chat_id" "$text" 2>/dev/null || true
                else
                    # Regular message - process
                    process_user_message "$text" "$message_id"
                fi
            fi
        fi

        # Update offset
        echo $((update_id + 1)) > "$OFFSET_FILE"
    done
}

# =============================================================================
# Harness hash — content (not mtime) of the files the agent's REPL bakes in
# at startup. The per-turn context hook (metasphere-context) compares the
# live hash to the baseline file written here and surfaces "your harness is
# stale, /exit to reload" to the agent if they differ. The agent decides
# whether to act. The host NEVER kills the REPL.
# =============================================================================

HARNESS_HASH_FILE="$METASPHERE_DIR/state/harness_hash_baseline"

# Files whose content is baked into a fresh claude REPL on startup.
# Listed via dynamic resolution so spot/laptop/etc all work.
harness_hash_files() {
    local files=(
        "$REPO_ROOT/CLAUDE.md"
        "$REPO_ROOT/.claude/settings.json"
        "$REPO_ROOT/.claude/settings.local.json"
        "$REPO_ROOT/scripts/metasphere-context"
    )
    for f in "${files[@]}"; do
        [[ -f "$f" ]] && echo "$f"
    done
}

compute_harness_hash() {
    local hash_cmd
    if command -v sha256sum >/dev/null 2>&1; then
        hash_cmd="sha256sum"
    elif command -v shasum >/dev/null 2>&1; then
        hash_cmd="shasum -a 256"
    else
        # Last-resort fallback: cksum (weaker but always present)
        hash_cmd="cksum"
    fi
    # Hash the concatenated CONTENT, not paths or mtimes. Sort the file
    # list so the result is stable across hosts.
    harness_hash_files | sort | xargs cat 2>/dev/null | $hash_cmd | awk '{print $1}'
}

write_harness_hash_baseline() {
    mkdir -p "$(dirname "$HARNESS_HASH_FILE")"
    compute_harness_hash > "$HARNESS_HASH_FILE"
}

# =============================================================================
# Supervisor: stuck-prompt detection only (lifecycle is the agent's job)
# =============================================================================

# Compute a stable signature of all watched config file mtimes.
#
# CAREFUL: stat syntax differs between BSD/macOS and Linux/GNU.
#   - macOS:  stat -f %m <file>   (-f = format)
#   - Linux:  stat -c %Y <file>   (-c = format; -f means "filesystem", which
#                                  silently returns garbage including free
#                                  block counts that change every tick)
# The previous version chained `stat -f %m ... || stat -c %Y` and on Linux
# the BSD form returned exit 0 with garbage output, so the fallback never
# fired and the signature thrashed on each watchdog tick — causing a
# perpetual "config changed" reboot loop.
compute_config_signature() {
    local sig=""
    local stat_cmd
    if [[ "$(uname)" == "Darwin" ]]; then
        stat_cmd="stat -f %m"
    else
        stat_cmd="stat -c %Y"
    fi
    for f in "${WATCHED_CONFIG_FILES[@]}"; do
        if [[ -f "$f" ]]; then
            local mt
            mt=$($stat_cmd "$f" 2>/dev/null || echo 0)
            sig+="$f:$mt;"
        else
            sig+="$f:missing;"
        fi
    done
    echo "$sig"
}

# Restart only the claude process inside the orchestrator tmux session,
# leaving the tmux session itself intact. The watchdog/start_session logic
# will not see the session as dead, so we re-run claude manually here.
restart_claude_in_session() {
    local reason="$1"
    if ! session_alive; then
        supervisor_log "restart_claude_in_session: session not alive, will let revive logic spawn it ($reason)"
        return 0
    fi

    supervisor_log "Restarting claude in $SESSION_NAME: $reason"
    "$SCRIPT_DIR/metasphere-events" log supervisor.restart_claude "$reason" --agent @daemon-supervisor 2>/dev/null || true

    # Send Ctrl-C twice to interrupt + exit any prompt, then exit the claude REPL
    $TMUX_CMD send-keys -t "$SESSION_NAME" C-c 2>/dev/null || true
    sleep 0.3
    $TMUX_CMD send-keys -t "$SESSION_NAME" C-c 2>/dev/null || true
    sleep 0.3
    # Try graceful /exit first
    $TMUX_CMD send-keys -t "$SESSION_NAME" "/exit" Enter 2>/dev/null || true
    sleep 1
    # Hard kill any lingering claude child of the tmux pane
    local pane_pid
    pane_pid=$($TMUX_CMD display-message -t "$SESSION_NAME" -p '#{pane_pid}' 2>/dev/null || echo "")
    if [[ -n "$pane_pid" ]]; then
        # Kill any claude descendants of the pane
        pkill -P "$pane_pid" -f "claude" 2>/dev/null || true
    fi
    sleep 0.5

    # NOTE: this CLI-only restart path used to relaunch claude bare and
    # then inject build_initial_context (33KB+ of persona files) via slow
    # literal-mode tmux typing — locked the pane and exhausted context.
    # The respawn loop in start_session means a /exit alone is enough,
    # but if we're nuking claude from outside we relaunch the loop too.
    # No context is injected; CLAUDE.md auto-loads on startup.
    $TMUX_CMD send-keys -t "$SESSION_NAME" \
      "exec bash -c 'while true; do claude --dangerously-skip-permissions; ec=\$?; echo \"[gateway] claude exited (\$ec), respawning in 1s...\"; sleep 1; done'" Enter
    sleep 3

    supervisor_log "Claude restart sequence complete in $SESSION_NAME"
}

# Watch config files; if any mtime changed since last tick, restart claude.
check_config_changes() {
    local current_sig
    current_sig=$(compute_config_signature)

    local last_sig=""
    [[ -f "$CONFIG_MTIME_FILE" ]] && last_sig=$(cat "$CONFIG_MTIME_FILE")

    if [[ -z "$last_sig" ]]; then
        # First run - just record baseline
        echo "$current_sig" > "$CONFIG_MTIME_FILE"
        return 0
    fi

    if [[ "$current_sig" != "$last_sig" ]]; then
        supervisor_log "Config change detected"
        supervisor_log "  old: $last_sig"
        supervisor_log "  new: $current_sig"
        echo "$current_sig" > "$CONFIG_MTIME_FILE"
        restart_claude_in_session "config file mtime changed"
    fi
}

# Detect known stuck-prompt patterns in tmux pane and auto-resolve.
check_stuck_prompts() {
    session_alive || return 0

    local pane
    pane=$($TMUX_CMD capture-pane -t "$SESSION_NAME" -p -S -50 2>/dev/null || echo "")
    [[ -z "$pane" ]] && return 0

    # Safety-hooks / generic confirmation prompt / initial trust prompt: auto-approve "1" or Enter
    # Patterns:
    #   - "[plugin:safety-hooks]" prompts
    #   - "Do you want to proceed?"
    #   - "1. Yes" style confirmations
    #   - Initial trust prompt: "Yes, I trust this folder"
    if echo "$pane" | grep -qE "(Do you want to proceed\?|\[plugin:safety-hooks\]|^[[:space:]]*1\.[[:space:]]+Yes\b|Yes, I trust this folder)"; then
        # Avoid spamming: only intervene if we haven't just intervened
        local marker="$METASPHERE_DIR/state/last_safety_hook_intervention"
        local now=$(date +%s)
        local last=0
        [[ -f "$marker" ]] && last=$(cat "$marker")
        if (( now - last >= 10 )); then
            supervisor_log "Stuck safety-hooks confirmation detected; sending '1' Enter"
            "$SCRIPT_DIR/metasphere-events" log supervisor.auto_approve "Safety-hooks confirmation auto-approved" --agent @daemon-supervisor 2>/dev/null || true
            $TMUX_CMD send-keys -t "$SESSION_NAME" "1" 2>/dev/null || true
            sleep 0.2
            $TMUX_CMD send-keys -t "$SESSION_NAME" Enter 2>/dev/null || true
            echo "$now" > "$marker"
        fi
        return 0
    fi

    # Stuck "[Pasted text #N" placeholder for >15s
    if echo "$pane" | grep -qE "\[Pasted text #[0-9]+"; then
        local now=$(date +%s)
        local first=0
        [[ -f "$STUCK_PASTE_STATE" ]] && first=$(cat "$STUCK_PASTE_STATE")
        if (( first == 0 )); then
            echo "$now" > "$STUCK_PASTE_STATE"
        elif (( now - first >= 15 )); then
            supervisor_log "Stuck [Pasted text] placeholder >15s; force Enter"
            "$SCRIPT_DIR/metasphere-events" log supervisor.force_enter "Stuck pasted-text placeholder cleared" --agent @daemon-supervisor 2>/dev/null || true
            $TMUX_CMD send-keys -t "$SESSION_NAME" Enter 2>/dev/null || true
            rm -f "$STUCK_PASTE_STATE"
        fi
    else
        # No placeholder - clear timer
        [[ -f "$STUCK_PASTE_STATE" ]] && rm -f "$STUCK_PASTE_STATE" || true
    fi
}

# =============================================================================
# Watchdog
# =============================================================================

run_watchdog() {
    log "Watchdog check"

    if [[ "$SESSION_MODE" == "persistent" ]]; then
        if ! session_alive; then
            log "Session dead, reviving..."
            "$SCRIPT_DIR/metasphere-events" log watchdog.revive "Reviving orchestrator session" --agent @watchdog 2>/dev/null || true
            start_session
            return
        fi

        # Stuck-paste watchdog: if a "[Pasted text #" placeholder is lingering
        # in the orchestrator session, the previous paste's Enter got eaten by
        # the bracketed-paste race. Force Enter to submit.
        if TMUX_CMD="$TMUX_CMD" tmux_submit_watchdog "$SESSION_NAME"; then
            :
        else
            log "Watchdog: stuck paste in $SESSION_NAME could not be cleared"
            "$SCRIPT_DIR/metasphere-events" log watchdog.stuck_paste "Stuck [Pasted text] placeholder" --agent @watchdog 2>/dev/null || true
        fi

        # Supervisor behaviors — cognitive lifecycle is the AGENT's job
        # now (it self-/exits via the respawn loop). Only stuck-prompt
        # recovery stays here, because that's "agent is frozen, unstick
        # it" not "agent's harness is stale, reload it".
        check_stuck_prompts
    fi
}

# Restart claude inside the orchestrator session on demand (CLI)
restart_orchestrator_claude() {
    if ! session_alive; then
        echo "Session $SESSION_NAME not alive; starting fresh"
        start_session
        return 0
    fi
    restart_claude_in_session "explicit CLI restart-orchestrator"
    echo "Restart triggered. Watch: tail -f $SUPERVISOR_LOG"
}

# =============================================================================
# Daemon Mode
# =============================================================================

daemon_mode() {
    local interval="${1:-3}"
    local watchdog_interval=5
    local last_watchdog=0

    log "Starting gateway daemon (poll: ${interval}s, mode: $SESSION_MODE)"

    # Ensure session on startup
    [[ "$SESSION_MODE" == "persistent" ]] && ensure_session

    # NOTE: We deliberately do NOT restart the claude REPL on daemon boot.
    # The agent owns its own lifecycle now (see task-20260407-6611). If a
    # harness update needs to be picked up, the per-turn metasphere-context
    # hook surfaces a STALE warning and the agent decides to /exit; the
    # tmux pane's respawn loop then launches a fresh REPL with the latest
    # harness. The host does not control cognition.
    #
    # Refresh the baseline so an existing-on-startup session uses the
    # latest harness as its reference point.
    write_harness_hash_baseline

    while true; do
        poll_telegram 2>/dev/null || true

        # Watchdog check
        local now=$(date +%s)
        if (( now - last_watchdog >= watchdog_interval )); then
            run_watchdog
            last_watchdog=$now
        fi

        sleep "$interval"
    done
}

# =============================================================================
# Main Dispatch
# =============================================================================

case "${1:-}" in
    daemon|run)
        daemon_mode "${2:-3}"
        ;;
    inject|send)
        shift
        ensure_session
        inject_to_session "$*"
        ;;
    ensure|start)
        ensure_session
        echo "Session: $(session_info)"
        ;;
    status|info)
        echo "Session: $(session_info)"
        echo "Mode: $SESSION_MODE"
        echo "Telegram: ${TELEGRAM_CHAT_ID:-not configured}"
        ;;
    attach)
        if session_alive; then
            $TMUX_CMD attach-session -t "$SESSION_NAME"
        else
            echo "No session running"
        fi
        ;;
    restart-orchestrator|restart-claude)
        restart_orchestrator_claude
        ;;
    kill|stop)
        $TMUX_CMD kill-session -t "$SESSION_NAME" 2>/dev/null || true
        echo "Session killed"
        ;;
    context)
        build_full_context "${2:-test message}"
        ;;
    *)
        cat << 'EOF'
metasphere-gateway - Persistent session orchestrator

Usage:
  metasphere-gateway daemon [N]    Run gateway with watchdog
  metasphere-gateway inject "msg"  Send to orchestrator session
  metasphere-gateway ensure        Start session if needed
  metasphere-gateway status        Check session status
  metasphere-gateway attach        Attach to session (Ctrl+b d to detach)
  metasphere-gateway kill          Stop session

Modes (set METASPHERE_SESSION_MODE):
  persistent   Single long-running session (default)
  per-message  Fresh session per message

The watchdog monitors session health and revives if needed.
EOF
        exit 1
        ;;
esac
