#!/bin/bash
# metasphere-context - Precommand hook that injects messages + tasks + CAM + Telegram
# Called before each agent turn via Claude Code UserPromptSubmit hook
#
# Injection order (most actionable first):
#   1. Agent identity (MISSION, HEARTBEAT, LEARNINGS)
#   2. Telegram (last few messages for conversation continuity, truncated)
#   3. Child agent reports (completion messages bubble up)
#   4. Agent messages (inter-agent communication)
#   5. Tasks (what needs doing)
#   6. Recent events (situational awareness)
#   7. CAM (relevant memory - keyed to current task)

REPO_ROOT="${METASPHERE_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
METASPHERE_DIR="${METASPHERE_DIR:-$HOME/.metasphere}"
AGENT="${METASPHERE_AGENT_ID:-@orchestrator}"
SCOPE="${METASPHERE_SCOPE:-$REPO_ROOT}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
AGENT_DIR="$METASPHERE_DIR/agents/$AGENT"

# Export for child scripts
export METASPHERE_REPO_ROOT="$REPO_ROOT"
export METASPHERE_SCOPE="$SCOPE"
export METASPHERE_AGENT_ID="$AGENT"

# Tiny header
echo "# Metasphere Context ($AGENT)"
echo ""

# =============================================================================
# 0. Legacy openclaw workspace (read live, never copied)
# =============================================================================
# If the host previously ran openclaw, the user's authoritative SOUL/IDENTITY/
# AGENTS/USER/TOOLS/MEMORY files live in ~/.openclaw/workspace/. We register
# that path during install (via metasphere-migrate) and inject the relevant
# files here on every turn so the agent inherits the openclaw persona and
# operating rules without us copying them. This keeps openclaw and metasphere
# in lockstep if the user keeps editing the workspace files.
OPENCLAW_WS=""
if [[ -f "$METASPHERE_DIR/config/openclaw_workspace" ]]; then
    OPENCLAW_WS=$(cat "$METASPHERE_DIR/config/openclaw_workspace" 2>/dev/null)
elif [[ -d "$HOME/.openclaw/workspace" ]]; then
    OPENCLAW_WS="$HOME/.openclaw/workspace"
fi

if [[ -n "$OPENCLAW_WS" && -d "$OPENCLAW_WS" ]]; then
    echo "## OpenClaw Workspace (legacy harness)"
    echo ""
    echo "_Source: \`$OPENCLAW_WS\` — edits to these files are picked up live._"
    echo ""

    # SOUL: who you are. Always inject in full if reasonable size.
    if [[ -f "$OPENCLAW_WS/SOUL.md" ]]; then
        echo "### SOUL"
        head -60 "$OPENCLAW_WS/SOUL.md"
        echo ""
    fi

    # IDENTITY: name, role, ID metadata.
    if [[ -f "$OPENCLAW_WS/IDENTITY.md" ]]; then
        echo "### IDENTITY"
        head -30 "$OPENCLAW_WS/IDENTITY.md"
        echo ""
    fi

    # USER: who the human is.
    if [[ -f "$OPENCLAW_WS/USER.md" ]]; then
        echo "### USER"
        head -40 "$OPENCLAW_WS/USER.md"
        echo ""
    fi

    # TOOLS: local conventions, channel IDs, device nicknames.
    if [[ -f "$OPENCLAW_WS/TOOLS.md" ]]; then
        echo "### TOOLS / local conventions"
        head -40 "$OPENCLAW_WS/TOOLS.md"
        echo ""
    fi

    # AGENTS: procedural rules. This is the largest workspace file (~17K on
    # the reference install). Inject as a header pointer with first 50 lines
    # so the agent knows it exists and can Read it in full when relevant.
    if [[ -f "$OPENCLAW_WS/AGENTS.md" ]]; then
        echo "### AGENTS (operational rules — first 50 lines, full file at \`$OPENCLAW_WS/AGENTS.md\`)"
        head -50 "$OPENCLAW_WS/AGENTS.md"
        echo ""
    fi

    # MEMORY: curated long-term memory. Inject in full if short.
    if [[ -f "$OPENCLAW_WS/MEMORY.md" ]]; then
        local mem_lines
        mem_lines=$(wc -l < "$OPENCLAW_WS/MEMORY.md" | tr -d ' ')
        echo "### MEMORY"
        if [[ $mem_lines -le 60 ]]; then
            cat "$OPENCLAW_WS/MEMORY.md"
        else
            tail -40 "$OPENCLAW_WS/MEMORY.md"
            echo ""
            echo "_(truncated to last 40 lines of $mem_lines; full at \`$OPENCLAW_WS/MEMORY.md\`)_"
        fi
        echo ""
    fi
fi

# =============================================================================
# 1. Agent Identity - who you are and what you're doing
# =============================================================================
if [[ -d "$AGENT_DIR" ]]; then
    echo "## Agent Identity ($AGENT)"
    echo ""

    # Current status and task
    agent_status=$(cat "$AGENT_DIR/status" 2>/dev/null || echo "unknown")
    agent_task=$(cat "$AGENT_DIR/task" 2>/dev/null || echo "")
    echo "**Status:** $agent_status"
    [[ -n "$agent_task" ]] && echo "**Task:** $agent_task"
    echo ""

    # Mission (if exists and short enough)
    if [[ -f "$AGENT_DIR/MISSION.md" ]]; then
        echo "### Mission"
        head -30 "$AGENT_DIR/MISSION.md" | tail -n +2  # Skip # header
        echo ""
    fi

    # Recent learnings (just section headers or last few entries)
    if [[ -f "$AGENT_DIR/LEARNINGS.md" ]]; then
        learnings_lines=$(wc -l < "$AGENT_DIR/LEARNINGS.md" | tr -d ' ')
        if [[ $learnings_lines -gt 0 && $learnings_lines -le 50 ]]; then
            echo "### Recent Learnings"
            cat "$AGENT_DIR/LEARNINGS.md"
            echo ""
        elif [[ $learnings_lines -gt 50 ]]; then
            echo "### Recent Learnings (last 20 lines)"
            tail -20 "$AGENT_DIR/LEARNINGS.md"
            echo ""
        fi
    fi

    # Heartbeat (current operational state)
    if [[ -f "$AGENT_DIR/HEARTBEAT.md" ]]; then
        echo "### Heartbeat"
        cat "$AGENT_DIR/HEARTBEAT.md"
        echo ""
    fi
fi

# =============================================================================
# 2. Telegram - last few messages (truncated: max 3 msgs, ~1KB)
# =============================================================================
if [[ -x "$SCRIPT_DIR/metasphere-telegram-stream" ]]; then
    tg_output=$("$SCRIPT_DIR/metasphere-telegram-stream" context --history 3 2>/dev/null || true)
    if [[ -n "$tg_output" ]]; then
        # Cap at ~1KB to prevent dominating context
        echo "$tg_output" | head -c 1024
        # If truncated, note it
        tg_bytes=$(printf '%s' "$tg_output" | wc -c | tr -d ' ')
        if [[ $tg_bytes -gt 1024 ]]; then
            echo ""
            echo "_(telegram context truncated: $tg_bytes bytes total)_"
        fi
        echo ""
    fi
fi

# =============================================================================
# 3. Child Agent Reports (completion messages bubble up)
# =============================================================================
if [[ -d "$AGENT_DIR/child_reports" ]]; then
    report_count=$(ls "$AGENT_DIR/child_reports"/*.md 2>/dev/null | wc -l | tr -d ' ')
    if [[ $report_count -gt 0 ]]; then
        echo "## Child Agent Reports ($report_count pending)"
        echo ""
        # Show last 5 reports
        ls -t "$AGENT_DIR/child_reports"/*.md 2>/dev/null | head -5 | while read -r f; do
            child=$(basename "$f" | cut -d- -f1)
            echo "### @$child"
            cat "$f"
            echo ""
        done
    fi
fi

# =============================================================================
# 3. Messages - inter-agent communication
# =============================================================================
"$SCRIPT_DIR/messages" 2>/dev/null || echo "## Messages: Error loading messages"
echo ""

# =============================================================================
# 4. Tasks - what needs doing
# =============================================================================
"$SCRIPT_DIR/tasks" 2>/dev/null || echo "## Tasks: Error loading tasks"
echo ""

# =============================================================================
# 5. Recent Events - situational awareness
# =============================================================================
if [[ -x "$SCRIPT_DIR/metasphere-events" ]]; then
    echo "## Recent Events"
    "$SCRIPT_DIR/metasphere-events" tail 10 2>/dev/null || echo "(no recent events)"
    echo ""
fi

# =============================================================================
# 6. Memory Context - fast FTS+BM25 ranker over local corpus
# =============================================================================
# Per-turn memory uses metasphere-fts (ripgrep + token-overlap scoring) for
# sub-500ms latency. `cam search <query>` remains available for explicit,
# entity-enriched discovery when an agent needs deeper semantic recall.
echo "## Memory Context (FTS)"

# Build query from task + project name
QUERY=""
TASK_FILE="$AGENT_DIR/task"
if [[ -f "$TASK_FILE" ]]; then
    QUERY=$(cat "$TASK_FILE")
fi
if [[ -n "$REPO_ROOT" ]]; then
    QUERY="$QUERY $(basename "$REPO_ROOT")"
fi
QUERY=$(echo "$QUERY" | tr '\n' ' ' | sed 's/  */ /g' | head -c 200)

if [[ -z "$QUERY" ]]; then
    QUERY="@$AGENT"
fi

if [[ -x "$SCRIPT_DIR/metasphere-fts" ]]; then
    "$SCRIPT_DIR/metasphere-fts" "$QUERY" 5 2>/dev/null || echo "No relevant memory found."
else
    echo "metasphere-fts not found. (Tip: \`cam search <query>\` for deeper recall.)"
fi
