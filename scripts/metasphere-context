#!/bin/bash
# metasphere-context - Precommand hook that injects messages + tasks + CAM + Telegram
# Called before each agent turn via Claude Code UserPromptSubmit hook
#
# Injection order (most actionable first):
#   1. Agent identity (MISSION, HEARTBEAT, LEARNINGS)
#   2. Telegram (last few messages for conversation continuity, truncated)
#   3. Child agent reports (completion messages bubble up)
#   4. Agent messages (inter-agent communication)
#   5. Tasks (what needs doing)
#   6. Recent events (situational awareness)
#   7. CAM (relevant memory - keyed to current task)

REPO_ROOT="${METASPHERE_REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
METASPHERE_DIR="${METASPHERE_DIR:-$HOME/.metasphere}"
AGENT="${METASPHERE_AGENT_ID:-@orchestrator}"
SCOPE="${METASPHERE_SCOPE:-$REPO_ROOT}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
AGENT_DIR="$METASPHERE_DIR/agents/$AGENT"

# Export for child scripts
export METASPHERE_REPO_ROOT="$REPO_ROOT"
export METASPHERE_SCOPE="$SCOPE"
export METASPHERE_AGENT_ID="$AGENT"

# Per-turn header. We inject a compact "voice capsule" every turn so the
# agent's persona (SOUL.md) stays resident in context — without this, the
# agent runs on CLAUDE.md's terseness defaults and drifts into flat,
# technical replies between turns. The rest of the persona stack (IDENTITY,
# USER, TOOLS, AGENTS, MEMORY, LEARNINGS) remains lazy-loaded via
# persona-index.md; SOUL.md and USER.md should also be Read once at fresh
# session start per the guidance in CLAUDE.md.
echo "# Metasphere Delta ($AGENT)"
echo ""

# Current status only (one line)
if [[ -d "$AGENT_DIR" ]]; then
    agent_status=$(cat "$AGENT_DIR/status" 2>/dev/null || echo "unknown")
    echo "_Status: $agent_status_"
    echo ""
fi

# =============================================================================
# 1. Voice capsule — keep SOUL resident so the agent doesn't drift to bland.
# =============================================================================
# Prefers an explicit VOICE.md (hand-tuned capsule) if present; otherwise
# falls back to the head of SOUL.md. Capped to ~1.5KB. This is the
# counterweight to the terseness defaults — brevity applies to filler, not
# to voice (see the Response Style section in CLAUDE.md).
voice_file=""
if [[ -f "$AGENT_DIR/VOICE.md" ]]; then
    voice_file="$AGENT_DIR/VOICE.md"
elif [[ -f "$AGENT_DIR/SOUL.md" ]]; then
    voice_file="$AGENT_DIR/SOUL.md"
fi
if [[ -n "$voice_file" ]]; then
    echo "## Voice (who you are, how you sound)"
    echo ""
    # Skip the top H1 line; emit up to line 40 or 1500 bytes, whichever hits first.
    sed -n '2,40p' "$voice_file" | head -c 1500
    echo ""
    echo ""
    echo "_(Full persona at \`$voice_file\` + persona-index.md. Read on demand for deeper context.)_"
    echo ""
fi

# =============================================================================
# 1b. Mission capsule — inject MISSION.md so all persistent agents know their
# purpose every turn, not just @orchestrator. Capped to ~1KB.
# =============================================================================
if [[ -f "$AGENT_DIR/MISSION.md" ]]; then
    echo "## Mission"
    echo ""
    sed -n '2,30p' "$AGENT_DIR/MISSION.md" | head -c 1024
    echo ""
    echo ""
fi

# =============================================================================
# 0. Stale-harness detection. The gateway writes a content-hash baseline of
# the files baked into the REPL on startup (CLAUDE.md, .claude/settings*.json,
# scripts/metasphere-context). If the live hash differs, the agent's baked
# context is out of date — surface a hint so the agent can decide whether to
# /exit (the tmux respawn loop will then launch a fresh REPL with the latest
# harness). The host never kills the REPL itself; this is the agent's call.
# =============================================================================
HARNESS_HASH_FILE="$METASPHERE_DIR/state/harness_hash_baseline"
if [[ -f "$HARNESS_HASH_FILE" ]]; then
    _harness_files=(
        "$REPO_ROOT/CLAUDE.md"
        "$REPO_ROOT/.claude/settings.json"
        "$REPO_ROOT/.claude/settings.local.json"
        "$REPO_ROOT/scripts/metasphere-context"
    )
    _existing=()
    for _f in "${_harness_files[@]}"; do
        [[ -f "$_f" ]] && _existing+=("$_f")
    done
    if (( ${#_existing[@]} > 0 )); then
        if command -v sha256sum >/dev/null 2>&1; then
            _hash_cmd="sha256sum"
        elif command -v shasum >/dev/null 2>&1; then
            _hash_cmd="shasum -a 256"
        else
            _hash_cmd="cksum"
        fi
        _live_hash=$(printf '%s\n' "${_existing[@]}" | sort | xargs cat 2>/dev/null | $_hash_cmd | awk '{print $1}')
        _baseline_hash=$(cat "$HARNESS_HASH_FILE" 2>/dev/null || echo "")
        if [[ -n "$_live_hash" && -n "$_baseline_hash" && "$_live_hash" != "$_baseline_hash" ]]; then
            echo "## ⚠ Harness drift detected"
            echo ""
            echo "Your baked-in CLAUDE.md / .claude/settings / metasphere-context has changed"
            echo "since this REPL started. The new content is on disk but you're still running"
            echo "the old version in memory."
            echo ""
            echo "If the change is relevant to what you're doing (e.g. updated workflow,"
            echo "new slash command, new safety rule), run \`/exit\` — the tmux pane will"
            echo "respawn a fresh REPL with the latest harness. Otherwise ignore this and"
            echo "the warning will keep appearing until you reload."
            echo ""
            echo "_(suppress: \`echo \$_live_hash > $HARNESS_HASH_FILE\` to silence without reloading)_"
            echo ""
        fi
    fi
fi

# =============================================================================
# 2. Telegram - last few messages (truncated: max 3 msgs, ~1KB)
# =============================================================================
if [[ -x "$SCRIPT_DIR/metasphere-telegram-stream" ]]; then
    tg_output=$("$SCRIPT_DIR/metasphere-telegram-stream" context --history 3 2>/dev/null || true)
    if [[ -n "$tg_output" ]]; then
        # Cap at ~1KB to prevent dominating context
        echo "$tg_output" | head -c 1024
        # If truncated, note it
        tg_bytes=$(printf '%s' "$tg_output" | wc -c | tr -d ' ')
        if [[ $tg_bytes -gt 1024 ]]; then
            echo ""
            echo "_(telegram context truncated: $tg_bytes bytes total)_"
        fi
        echo ""
    fi
fi

# =============================================================================
# 3. Child Agent Reports (completion messages bubble up)
# =============================================================================
if [[ -d "$AGENT_DIR/child_reports" ]]; then
    report_count=$(ls "$AGENT_DIR/child_reports"/*.md 2>/dev/null | wc -l | tr -d ' ')
    if [[ $report_count -gt 0 ]]; then
        echo "## Child Agent Reports ($report_count pending)"
        echo ""
        # Show last 5 reports
        ls -t "$AGENT_DIR/child_reports"/*.md 2>/dev/null | head -5 | while read -r f; do
            child=$(basename "$f" | cut -d- -f1)
            echo "### @$child"
            cat "$f"
            echo ""
        done
    fi
fi

# =============================================================================
# 3. Messages - inter-agent communication
# =============================================================================
"$SCRIPT_DIR/messages" 2>/dev/null || echo "## Messages: Error loading messages"
echo ""

# =============================================================================
# 4. Tasks - what needs doing
# =============================================================================
"$SCRIPT_DIR/tasks" 2>/dev/null || echo "## Tasks: Error loading tasks"
echo ""

# =============================================================================
# 5. Recent Events - situational awareness
# =============================================================================
if [[ -x "$SCRIPT_DIR/metasphere-events" ]]; then
    echo "## Recent Events"
    "$SCRIPT_DIR/metasphere-events" tail 10 2>/dev/null || echo "(no recent events)"
    echo ""
fi

# =============================================================================
# 6. Memory Context - fast FTS+BM25 ranker over local corpus
# =============================================================================
# Per-turn memory uses metasphere-fts (ripgrep + token-overlap scoring) for
# sub-500ms latency. `cam search <query>` remains available for explicit,
# entity-enriched discovery when an agent needs deeper semantic recall.
echo "## Memory Context (FTS)"

# Build query from task + project name
QUERY=""
TASK_FILE="$AGENT_DIR/task"
if [[ -f "$TASK_FILE" ]]; then
    QUERY=$(cat "$TASK_FILE")
fi
if [[ -n "$REPO_ROOT" ]]; then
    QUERY="$QUERY $(basename "$REPO_ROOT")"
fi
QUERY=$(echo "$QUERY" | tr '\n' ' ' | sed 's/  */ /g' | head -c 200)

if [[ -z "$QUERY" ]]; then
    QUERY="@$AGENT"
fi

if [[ -x "$SCRIPT_DIR/metasphere-fts" ]]; then
    "$SCRIPT_DIR/metasphere-fts" "$QUERY" 5 2>/dev/null || echo "No relevant memory found."
else
    echo "metasphere-fts not found. (Tip: \`cam search <query>\` for deeper recall.)"
fi
